<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Button.actionBtn">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.apply">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/> <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.apply:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.apply:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessPressedBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.apply:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/> </Style>

    <Style Selector="TextBlock.description">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.MediumGreyBrush}"/> <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Opacity" Value="0.8"/>
    </Style>

    <Style Selector="TextBox.valueInput">
        <Setter Property="Width" Value="85"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{DynamicResource ToolWindowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NavButtonForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="Padding" Value="5,0"/>
        <Setter Property="Margin" Value="10,0,0,0"/>
    </Style>

    <Style Selector="TextBlock.sectionTitle">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{DynamicResource NavButtonForegroundBrush}"/>
    </Style>

</Styles>