<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="StackPanel.NavControls TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/> 
        <Setter Property="Foreground" Value="White"/> 
    </Style>

    <Style Selector="Button.calculate">
        <Setter Property="Background" Value="{DynamicResource ActionPrimaryBackgroundBrush}"/> 
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.calculate:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionPrimaryHoverBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.calculate:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionPrimaryPressedBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.calculate:disabled">
        <Setter Property="Background" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <Style Selector="Button.apply">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessBackgroundBrush}"/> 
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.apply:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessHoverBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.apply:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessPressedBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.apply:disabled">
        <Setter Property="Background" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <Style Selector="Button.cancel">
        <Setter Property="Background" Value="{DynamicResource ActionDestructiveBackgroundBrush}"/> 
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.cancel:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionDestructiveHoverBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.cancel:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionDestructivePressedBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.cancel:disabled">
        <Setter Property="Background" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>
    
    <Style Selector="RadioButton.segmented">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#AAAAAA"/>
        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Padding" Value="16,8"/> 
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="RadioButton.segmented:pointerover">
        <Setter Property="Background" Value="#11FFFFFF"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="RadioButton.segmented:checked">
        <Setter Property="Background" Value="{DynamicResource ActionPrimaryBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ActionPrimaryBackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="ZIndex" Value="1"/> 
    </Style>

</Styles>