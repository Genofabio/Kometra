<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style Selector="Border.NodeFrame">
        <Setter Property="BorderBrush" Value="#3E3454"/>
        <Setter Property="BorderThickness" Value="18"/>
        <Setter Property="Background" Value="#3E3454"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="CornerRadius" Value="8"/> 
    </Style>

    <Style Selector="Border.NodeFrame.selected">
        <Setter Property="BorderBrush" Value="#8058E8"/>
        <Setter Property="Background" Value="#8058E8"/>
    </Style>

    <Style Selector="Button.CloseButton">
        <Setter Property="Background" Value="#353040"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0,8,0,0"/> 
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/> 
    </Style>
    
</Styles>