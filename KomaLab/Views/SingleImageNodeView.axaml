<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:KomaLab.ViewModels"
             xmlns:conv="clr-namespace:KomaLab.Converters"
             mc:Ignorable="d" 
             x:Class="KomaLab.Views.SingleImageNodeView"
             x:DataType="vm:SingleImageNodeViewModel"
             PointerPressed="OnPointerPressed"
             PointerReleased="OnPointerReleased"
             PointerMoved="OnPointerMoved"
             PointerWheelChanged="OnPointerWheelChanged"
             d:DesignWidth="200" 
             d:DesignHeight="150">
    
    <UserControl.Resources>
        <conv:NodeCategoryConverter x:Key="CatToClassConv" />
    </UserControl.Resources>

    <Border Classes="NodeFrame"
            Classes.selected="{Binding IsSelected}"
            Tag="{Binding Category, Converter={StaticResource CatToClassConv}}"
            
            Width="{Binding EstimatedTotalSize.Width}"
            MinWidth="150"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        
        <Grid RowDefinitions="Auto, Auto">
            
            <Border Grid.Row="0" Classes="Header"> 
                <Grid ColumnDefinitions="*,Auto">
                    
                    <TextBlock Grid.Column="0" 
                               Classes="NodeTitle"
                               Text="{Binding Title}"/> 
                               
                    <Button Grid.Column="1"
                            Content="✕"
                            Classes="CloseButton"
                            Command="{Binding RemoveSelfCommand}"
                            Width="{Binding $self.Bounds.Height}"/>
                </Grid>
            </Border>
            
            <Border Grid.Row="1" Classes="Body">
                <Image Source="{Binding FitsImage.Image}"
                       Stretch="None"
                       HorizontalAlignment="Center" 
                       RenderOptions.BitmapInterpolationMode="LowQuality"/>
            </Border>
            
        </Grid>
    </Border>
</UserControl>