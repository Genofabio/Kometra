<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:KomaLab.ViewModels"
             xmlns:views="clr-namespace:KomaLab.Views"
             xmlns:controls="clr-namespace:KomaLab.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="KomaLab.Views.BoardView"
             x:DataType="vm:BoardViewModel"
             ClipToBounds="False"
             PointerPressed="OnPointerPressed"
             PointerReleased="OnPointerReleased"
             PointerMoved="OnPointerMoved"
             PointerWheelChanged="OnPointerWheelChanged"
             SizeChanged="OnBoardSizeChanged">
    
    <Grid ClipToBounds="False">
        
        <controls:GridBackground OffsetX="{Binding OffsetX}"
                                 OffsetY="{Binding OffsetY}"
                                 Scale="{Binding Scale}" />

        <ItemsControl ItemsSource="{Binding Nodes}" 
                      Background="Transparent"
                      RenderTransformOrigin="0,0"
                      ClipToBounds="False">
            
            <ItemsControl.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                    <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}" />
                </TransformGroup>
            </ItemsControl.RenderTransform>

            <ItemsControl.DataTemplates>
                
                <DataTemplate DataType="vm:SingleImageNodeViewModel">
                    <views:SingleImageNodeView />
                </DataTemplate>
                
                <DataTemplate DataType="vm:MultipleImagesNodeViewModel">
                    <views:MultipleImagesNodeView />
                </DataTemplate>
                
            </ItemsControl.DataTemplates>

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Background="Transparent" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerTheme>
                <ControlTheme TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{ReflectionBinding X}" />
                    <Setter Property="Canvas.Top" Value="{ReflectionBinding Y}" />
                    <Setter Property="Canvas.ZIndex" Value="{ReflectionBinding ZIndex}" />
                </ControlTheme>
            </ItemsControl.ItemContainerTheme>

            </ItemsControl>
    </Grid>
</UserControl>