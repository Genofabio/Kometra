<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KomaLab.ViewModels"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="KomaLab.Views.AlignmentWindow"
        x:DataType="vm:AlignmentViewModel"
        Title="Allineamento"
        Width="800" Height="500"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Loaded="OnWindowLoaded">

    <Window.Styles>
        <Style Selector="StackPanel.ZoomControls Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#A0333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="300, *">
        
        <Border Grid.Column="0" Background="#2C2C2C" Padding="15">
            <Grid RowDefinitions="Auto, *, Auto">
                
                <StackPanel Grid.Row="0" Spacing="12">
                    <TextBlock Text="Metodologia di Allineamento" 
                               FontSize="16" FontWeight="Bold" />
                    <StackPanel Spacing="2">
                        <RadioButton Content="Automatico" GroupName="AlignmentMode" 
                                     IsChecked="True" />
                        <TextBlock Text="Rilevamento automatico del nucleo in tutte le immagini." 
                                   TextWrapping="Wrap" Margin="28,0,0,0" Opacity="0.7"/>
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <RadioButton Content="Guidato" GroupName="AlignmentMode" />
                        <TextBlock Text="Indica il nucleo sulla prima immagine per guidare il rilevamento." 
                                   TextWrapping="Wrap" Margin="28,0,0,0" Opacity="0.7"/>
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <RadioButton Content="Manuale" GroupName="AlignmentMode" />
                        <TextBlock Text="Ispeziona e imposta manualmente il centro per ogni immagine." 
                                   TextWrapping="Wrap" Margin="28,0,0,0" Opacity="0.7"/>
                    </StackPanel>
                    <Separator Margin="0,10"/>
                </StackPanel>
                
                <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                    <Button Grid.Column="0" Content="Annulla" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Center"
                            IsEnabled="True"/>
                    <Button Grid.Column="1" Content="Applica" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Center"
                            IsEnabled="False"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#1A1A1A" Padding="10">
            <Border Name="PreviewBorder"
                    Background="#222"
                    ClipToBounds="True"
                    PointerPressed="OnPreviewPointerPressed"
                    PointerReleased="OnPreviewPointerReleased"
                    PointerMoved="OnPreviewPointerMoved"
                    PointerWheelChanged="OnPreviewPointerWheelChanged"
                    SizeChanged="OnPreviewSizeChanged"> <Grid>
                    <Canvas Name="Viewport"
                            RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
                                <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>

                        <Image Name="PreviewImage"
                               Source="{Binding ActiveImage.Image}"
                               Stretch="None"
                               RenderOptions.BitmapInterpolationMode="None"
                               Canvas.Left="0"
                               Canvas.Top="0"/>
                        
                        <Canvas Name="InteractionCanvas"
                                Background="Transparent"
                                Width="{Binding ActiveImage.ImageSize.Width}"
                                Height="{Binding ActiveImage.ImageSize.Height}"
                                Canvas.Left="0"
                                Canvas.Top="0"
                                PointerPressed="OnInteractionCanvasPointerPressed"/>
                    </Canvas>
                    
                    <Canvas Name="TargetOverlayCanvas"
                            IsHitTestVisible="False">
                        <Path Data="M0,10 L20,10 M10,0 L10,20"
                              Stroke="#FF0000"
                              StrokeThickness="1">
                            <Path.IsVisible>
                                <Binding Path="IsTargetMarkerVisible" />
                            </Path.IsVisible>
                            <Canvas.Left>
                                <Binding Path="TargetMarkerScreenX" />
                            </Canvas.Left>
                            <Canvas.Top>
                                <Binding Path="TargetMarkerScreenY" />
                            </Canvas.Top>
                            <Path.RenderTransform>
                                <TranslateTransform X="-10" Y="-10" />
                            </Path.RenderTransform>
                        </Path>
                    </Canvas>
                    
                    <StackPanel 
                        Orientation="Horizontal" 
                        Spacing="4" 
                        Margin="10"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Bottom"
                        ZIndex="1"
                        Classes="ZoomControls"> <Button Name="ZoomOutButton"
                                ToolTip.Tip="Zoom Out">
                            <avalonia:MaterialIcon Kind="Minus" Width="16" Height="16" />
                        </Button>
                        <Button Name="ZoomInButton"
                                ToolTip.Tip="Zoom In">
                            <avalonia:MaterialIcon Kind="Plus" Width="16" Height="16" />
                        </Button>
                        <Button Name="ResetViewButton" Margin="8,0,0,0"
                                ToolTip.Tip="Reset View (Zoom &amp; Pan)">
                            <avalonia:MaterialIcon Kind="FitToScreen" Width="16" Height="16" />
                        </Button>
                        
                        <Path Data="M0,0 V18" Stroke="#666666" StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
            
                        <Button Name="ResetThresholdsButton"
                                ToolTip.Tip="Reset Stretch (Livelli)"
                                Command="{Binding ResetThresholdsCommand}">
                            <avalonia:MaterialIcon Kind="Contrast" Width="16" Height="16" />
                        </Button>
                        
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
        
    </Grid>
</Window>