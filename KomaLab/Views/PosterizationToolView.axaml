<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KomaLab.ViewModels"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:models="clr-namespace:KomaLab.Models"
        xmlns:conv="clr-namespace:KomaLab.Converters"
        mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="650"
        x:Class="KomaLab.Views.PosterizationToolView"
        x:DataType="vm:PosterizationToolViewModel"
        Title="Analisi Morfologica / Posterizzazione"
        Width="1000" Height="700"
        MinHeight="500" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ToolWindowBackgroundBrush}"
        Focusable="True">

    <Window.Resources>
        <conv:PosterizationModeConverter x:Key="ModeConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.actionBtn">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.apply">
            <Setter Property="Background" Value="{DynamicResource ActionSuccessBackgroundBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.apply:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ActionSuccessHoverBrush}"/>
        </Style>
        
        <Style Selector="TextBlock.description">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style Selector="TextBox.valueInput">
            <Setter Property="Width" Value="85"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>
    
    <Grid ColumnDefinitions="320, *">
        <Border Grid.Column="0" Background="{DynamicResource ToolPanelBackgroundBrush}" Padding="10,14,10,6">
            <Grid RowDefinitions="Auto, *, Auto">
                <TextBlock Grid.Row="0" Text="Parametri Quantizzazione" FontSize="22" FontWeight="Bold" Foreground="White" Margin="5,0,0,15"/>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="15" Margin="5,0,14,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Numero Livelli" FontWeight="SemiBold" FontSize="14" Foreground="#CCC"/>
                            <TextBlock Classes="description" Text="Divide l'immagine in toni discreti per isolare le isofote."/>
                            <Grid ColumnDefinitions="*, Auto">
                                <Slider Grid.Column="0" Minimum="2" Maximum="64" Value="{Binding Levels}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
                                <TextBox Name="LevelsInput" Grid.Column="1" Text="{Binding Levels, Mode=OneWay}" LostFocus="OnValueInputLostFocus" Classes="valueInput"/>
                            </Grid>
                        </StackPanel>
                        <Border Height="1" Background="#444" Margin="0,0,0,2"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Metodo Distribuzione" FontWeight="SemiBold" FontSize="14" Foreground="#CCC"/>
                            <TextBlock Classes="description" Text="Scegli come ripartire i toni per enfatizzare dettagli deboli."/>
                            <ComboBox ItemsSource="{Binding AvailableModes}" SelectedItem="{Binding SelectedMode}" HorizontalAlignment="Stretch" Margin="0,8,0,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Converter={StaticResource ModeConverter}}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <Border Height="1" Background="#444" Margin="0,6,0,2"/>
                        <StackPanel Spacing="10">
                            <TextBlock Text="Range Dinamico (Clip)" FontWeight="SemiBold" FontSize="14" Foreground="#CCC"/>
                            <TextBlock Classes="description" Text="Definisce l'intervallo di segnale ADU. I valori esterni verranno tagliati."/>
                            <StackPanel Spacing="2" Margin="0,2,0,0">
                                <TextBlock Text="Soglia Nero" FontSize="12" Foreground="#999" FontWeight="SemiBold" FontStyle="Italic"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <Slider Grid.Column="0" Minimum="{Binding SliderMin}" Maximum="{Binding SliderMax}" Value="{Binding BlackPoint}"/>
                                    <TextBox Name="BlackInput" Grid.Column="1" Text="{Binding BlackPoint, Mode=OneWay, StringFormat={}{0:0.0}}" LostFocus="OnValueInputLostFocus" Classes="valueInput"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Spacing="2" Margin="0,2,0,0">
                                <TextBlock Text="Soglia Bianco" FontSize="12" Foreground="#999" FontWeight="SemiBold" FontStyle="Italic"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <Slider Grid.Column="0" Minimum="{Binding SliderMin}" Maximum="{Binding SliderMax}" Value="{Binding WhitePoint}"/>
                                    <TextBox Name="WhiteInput" Grid.Column="1" Text="{Binding WhitePoint, Mode=OneWay, StringFormat={}{0:0.0}}" LostFocus="OnValueInputLostFocus" Classes="valueInput"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        <Border Height="1" Background="#444" Margin="0,0,0,2"/>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Opzioni aggiuntive" FontWeight="SemiBold" FontSize="14" Foreground="#CCC"/>
                            <CheckBox IsChecked="{Binding AutoAdaptThresholds}" Padding="8,0,0,0" FontSize="12" Content="Adatta luminosità al cambio immagine" Margin="0,0,0,6"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="5,12,5,0">
                    <Border Height="1" Background="#444" Margin="0,0,0,10"/>
                    <StackPanel Spacing="10">
                        <StackPanel Spacing="5" IsVisible="{Binding IsProcessing}">
                            <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" FontSize="12" FontStyle="Italic" Foreground="#AAA"/>
                            <ProgressBar IsIndeterminate="True" Height="4" Foreground="{DynamicResource ActionSuccessBackgroundBrush}"/>
                        </StackPanel>
                        <Button Content="Applica" Command="{Binding ApplyCommand}" Classes="actionBtn apply" IsEnabled="{Binding !IsProcessing}" Margin="0,8,0,10"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ToolWindowBackgroundBrush}" Padding="10">
            <Border Name="PreviewBorder" Background="{DynamicResource ToolPreviewBackgroundBrush}" ClipToBounds="True"
                    PointerPressed="OnPreviewPointerPressed"
                    PointerReleased="OnPreviewPointerReleased"
                    PointerMoved="OnPreviewPointerMoved"
                    PointerWheelChanged="OnPreviewPointerWheelChanged"
                    SizeChanged="OnPreviewSizeChanged">
                <Grid>
                    <Canvas Name="Viewport" RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Viewport.Scale}" ScaleY="{Binding Viewport.Scale}"/>
                                <TranslateTransform X="{Binding Viewport.OffsetX}" Y="{Binding Viewport.OffsetY}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                        <Image Name="PreviewImage" Source="{Binding PreviewBitmap}" Stretch="None" RenderOptions.BitmapInterpolationMode="None"/>
                        <Canvas Name="InteractionCanvas" Background="Transparent" 
                                Width="{Binding Viewport.ImageSize.Width}" 
                                Height="{Binding Viewport.ImageSize.Height}" />
                    </Canvas>

                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="8,4" 
                            Background="{DynamicResource OverlayTextBackgroundBrush}" CornerRadius="4" IsHitTestVisible="False">
                        <TextBlock Text="{Binding Viewport.Scale, StringFormat={}{0:P0}}" 
                                   Foreground="{DynamicResource OverlayTextForegroundBrush}" FontSize="14"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" ZIndex="1">
                        <Button Command="{Binding GoToFirstImageCommand}" ToolTip.Tip="Prima Immagine">
                            <avalonia:MaterialIcon Kind="ChevronDoubleLeft" Width="16" Height="16"/>
                        </Button>
                        <Button Command="{Binding PreviousImageCommand}" ToolTip.Tip="Immagine Precedente">
                            <avalonia:MaterialIcon Kind="ChevronLeft" Width="16" Height="16"/>
                        </Button>
                        <TextBlock Text="{Binding CurrentImageText}" VerticalAlignment="Center" Margin="8,0" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        <Button Command="{Binding NextImageCommand}" ToolTip.Tip="Immagine Successiva">
                            <avalonia:MaterialIcon Kind="ChevronRight" Width="16" Height="16"/>
                        </Button>
                        <Button Command="{Binding GoToLastImageCommand}" ToolTip.Tip="Ultima Immagine">
                            <avalonia:MaterialIcon Kind="ChevronDoubleRight" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" ZIndex="1">
                        <Button Click="OnZoomOutClicked" ToolTip.Tip="Zoom Out">
                            <avalonia:MaterialIcon Kind="Minus" Width="16" Height="16"/>
                        </Button>
                        <Button Click="OnZoomInClicked" ToolTip.Tip="Zoom In">
                            <avalonia:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                        </Button>
                        <Button Click="OnResetViewClicked" Margin="8,0,0,0" ToolTip.Tip="Adatta allo schermo">
                            <avalonia:MaterialIcon Kind="FitToScreen" Width="16" Height="16"/>
                        </Button>
                        <Path Data="M0,0 V18" Stroke="#666666" StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
                        <Button Command="{Binding ResetThresholdsCommand}" ToolTip.Tip="Reset Stretch (Livelli)">
                            <avalonia:MaterialIcon Kind="Contrast" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>