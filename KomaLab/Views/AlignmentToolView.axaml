<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:converters="clr-namespace:KomaLab.Converters"
        xmlns:av="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
        xmlns:processing="clr-namespace:KomaLab.Models.Processing"
        xmlns:imageProcessing="clr-namespace:KomaLab.ViewModels.ImageProcessing"
        xmlns:shared="clr-namespace:KomaLab.ViewModels.Shared"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="KomaLab.Views.AlignmentToolView"
        x:DataType="imageProcessing:AlignmentToolViewModel"
        Title="Allineamento"
        Width="800" Height="600"
        MinHeight="500" MinWidth="710"
        WindowStartupLocation="CenterScreen"
        Loaded="OnWindowLoaded"
        Focusable="True">

    <Window.Resources>
        <converters:EqualityConverter x:Key="EqualityConverter" />
        <converters:AlignmentModeNameConverter x:Key="AlignmentModeNameConverter" />
        <converters:EnumToBoolConverter x:Key="EnumToBool" />
        
        <DataTemplate x:Key="CoordinateItemTemplate" x:DataType="shared:CoordinateEntry">
            <Button Command="{Binding $parent[Window].((imageProcessing:AlignmentToolViewModel)DataContext).SelectImageCommand}" 
                    CommandParameter="{Binding}"
                    Padding="0" Margin="0,0,0,4"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Background="Transparent" BorderThickness="0">
                    
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="Button:pressed /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </Button.Styles>

                <Border Classes="CoordinateEntryRow" Classes.active="{Binding IsActive}">
                    <Grid ColumnDefinitions="40, *, *"> 
                        <Border Grid.Column="0" Classes="IndexBox" Background="{DynamicResource ActionPrimaryBackgroundBrush}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TextBlock Text="{Binding DisplayIndex}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" BorderBrush="{DynamicResource Border.WhiteDimBrush}" BorderThickness="0,0,1,0">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,6">
                                <TextBlock Text="X" Foreground="{DynamicResource Text.MediumGreyBrush}" FontSize="11" VerticalAlignment="Bottom" Opacity="0.7"/>
                                <TextBlock Text="{Binding FormattedX}" FontWeight="SemiBold" FontSize="13" />
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,6">
                            <TextBlock Text="Y" Foreground="{DynamicResource Text.MediumGreyBrush}" FontSize="11" VerticalAlignment="Bottom" Opacity="0.7"/>
                            <TextBlock Text="{Binding FormattedY}" FontWeight="SemiBold" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="/Styles/AlignmentToolStyles.axaml" />
    </Window.Styles>
    
    <Grid ColumnDefinitions="300, *">
        <Border Grid.Column="0" Background="{DynamicResource ToolPanelBackgroundBrush}" Padding="15" IsEnabled="{Binding IsInteractionEnabled}">
            <Grid RowDefinitions="Auto, *, Auto">
                
                <StackPanel Grid.Row="0" Spacing="10">
                    <StackPanel x:Name="SetupContainer" Spacing="10" 
                                IsVisible="{Binding IsSetupVisible}" 
                                IsEnabled="{Binding IsSetupControlsEnabled}">
                        
                        <StackPanel Spacing="12">
                            <TextBlock Text="Oggetto dell'allineamento" FontSize="16" FontWeight="Bold" />
                            <Grid ColumnDefinitions="*,*">
                                <RadioButton Grid.Column="0" 
                                             GroupName="TargetGroup" 
                                             Content="Cometa" 
                                             Classes="segmented"
                                             IsChecked="{Binding SelectedTarget, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static processing:AlignmentTarget.Comet}}"
                                             Classes.solo="{Binding !IsMultipleImages}">
                                    <RadioButton.Styles>
                                        <Style Selector="RadioButton.segmented">
                                            <Setter Property="CornerRadius" Value="4,0,0,4" />
                                            <Setter Property="BorderThickness" Value="1,1,0,1" />
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        </Style>
                                        <Style Selector="RadioButton.segmented.solo">
                                            <Setter Property="CornerRadius" Value="4" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="Grid.ColumnSpan" Value="2" />
                                        </Style>
                                    </RadioButton.Styles>
                                </RadioButton>

                                <RadioButton Grid.Column="1" 
                                             GroupName="TargetGroup" 
                                             Content="Stelle" 
                                             Classes="segmented" 
                                             CornerRadius="0,4,4,0" 
                                             BorderThickness="1" 
                                             HorizontalAlignment="Stretch"
                                             IsVisible="{Binding IsMultipleImages}"
                                             IsChecked="{Binding SelectedTarget, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static processing:AlignmentTarget.Stars}}" />
                            </Grid>
                            <Separator Margin="0,5,0,5"/>
                        </StackPanel>

                        <StackPanel Spacing="12" IsVisible="{Binding SelectedTarget, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static processing:AlignmentTarget.Comet}}">
                            <TextBlock Text="Metodologia" FontSize="16" FontWeight="Bold" />
                            <ComboBox ItemsSource="{Binding AvailableModes}" SelectedItem="{Binding SelectedMode}" HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding ., Converter={StaticResource AlignmentModeNameConverter}}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            
                            <Panel MinHeight="40">
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" IsVisible="{Binding SelectedMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Automatic}">Rilevamento automatico del nucleo della cometa.</TextBlock>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" IsVisible="{Binding SelectedMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Guided}">Indica il nucleo sulla prima e ultima immagine.</TextBlock>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" IsVisible="{Binding SelectedMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Manual}">Ispeziona e imposta manualmente il centro per ogni immagine.</TextBlock>
                            </Panel>
                            <Separator Margin="0"/> 
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <TextBlock Text="Opzioni di Ricerca" FontSize="14" FontWeight="Bold" Margin="0, 8, 0, 0" />
                            
                            <StackPanel Spacing="2" IsVisible="{Binding IsJplOptionVisible}">
                                <CheckBox IsChecked="{Binding UseJplAstrometry}" Content="{Binding AstrometryOptionLabel}" Margin="0"/>
                                <StackPanel IsVisible="{Binding UseJplAstrometry}">
                                    <Grid ColumnDefinitions="*, Auto" Margin="0,5,0,5" IsVisible="{Binding IsTargetNameInputVisible}">
                                        <TextBox Grid.Column="0" Text="{Binding TargetName}" Watermark="Nome (es. 67P)" Margin="0,0,5,0"/>
                                        <Button Grid.Column="1" Command="{Binding VerifyJplCommand}" ToolTip.Tip="Verifica disponibilità dati" IsVisible="{Binding IsVerifyButtonVisible}">
                                            <StackPanel Orientation="Horizontal" Spacing="5"><avalonia:MaterialIcon Kind="LinkVariant" Width="16" Height="16"/><TextBlock Text="Verifica"/></StackPanel>
                                        </Button>
                                    </Grid>
                                    <ProgressBar IsIndeterminate="True" Height="2" IsVisible="{Binding IsVerifyingJpl}" 
                                                 Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/>
    
                                    <TextBlock Text="{Binding AstrometryStatusMessage}" 
                                               FontSize="11" 
                                               TextWrapping="Wrap" 
                                               Margin="2,4,0,0">
        
                                        <TextBlock.Tag>
                                            <Binding Path="AstrometryStatus" />
                                        </TextBlock.Tag>

                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource Text.MediumGreyBrush}"/>
                                            </Style>
            
                                            <Style Selector="TextBlock[Tag=Success]">
                                                <Setter Property="Foreground" Value="{DynamicResource ActionSuccessBackgroundBrush}"/>
                                            </Style>
            
                                            <Style Selector="TextBlock[Tag=Error]">
                                                <Setter Property="Foreground" Value="{DynamicResource ActionDestructiveBackgroundBrush}"/>
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="5" Margin="0" IsVisible="{Binding IsSearchRadiusVisible}">
                                <TextBlock Text="Raggio di Ricerca (px):"/> 
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                    <TextBox Grid.Column="0" Name="SearchRadiusTextBox" Text="{Binding SearchRadius, Mode=OneWay}" MinWidth="45" VerticalAlignment="Center" HorizontalContentAlignment="Right" GotFocus="OnSearchRadiusTextBoxGotFocus" LostFocus="OnSearchRadiusTextBoxLostFocus"/>
                                    <Slider Grid.Column="1" Minimum="{Binding MinSearchRadius}" Maximum="{Binding MaxSearchRadius}" Value="{Binding SearchRadius}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Spacing="5" IsVisible="{Binding IsResultsListVisible}">
                        <TextBlock Text="{Binding ResultsSectionTitle}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.7" Text="{Binding ResultsSectionDescription}" IsVisible="{Binding IsTargetPlacementAllowed}"/>
                        <Separator Margin="0,10"/>
                        <TextBlock Text="{Binding CoordinateListHeader}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    </StackPanel>
                </StackPanel>
                
                <ScrollViewer Grid.Row="1" Margin="0,5,0,0" VerticalScrollBarVisibility="Auto" IsVisible="{Binding IsResultsListVisible}">
                    <ItemsControl ItemsSource="{Binding CoordinateEntries}" ItemTemplate="{StaticResource CoordinateItemTemplate}"/>
                </ScrollViewer>
                
                <StackPanel Grid.Row="2" Spacing="10" Margin="0,15,0,0">
                    
                    <Separator Margin="0,0,0,5" IsVisible="{Binding IsResultsListVisible}"/>

                    <StackPanel Spacing="6" 
                                IsEnabled="{Binding IsInteractionEnabled}"
                                IsVisible="{Binding IsResultsListVisible}">
                        <TextBlock Text="Opzioni di Salvataggio" FontSize="14" FontWeight="Bold"/>
                        <CheckBox IsChecked="{Binding CropToCommonArea}" 
                                  Margin="0,0,0,5"
                                  Content="Ritaglia all'area comune">
                            <ToolTip.Tip>
                                <TextBlock Text="Se attivo, ritaglia l'immagine finale sull'area comune a tutti i frame, eliminando i bordi neri, ma mantenendo il centro e le proporzioni."/>
                            </ToolTip.Tip>
                        </CheckBox>
                    </StackPanel>

                    <Separator Margin="0,0,0,10"/>

                    <Button Content="{Binding CalculateButtonText}" Command="{Binding CalculateCentersCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" IsVisible="{Binding IsCalculateButtonVisible}" Classes="calculate"/> 
                    
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" IsVisible="{Binding IsApplyCancelButtonsVisible}">
                        <Button Grid.Column="0" Content="Annulla" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding CancelCommand}" Classes="cancel"/> 
                        <Button Grid.Column="1" Content="Applica" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding ApplyAlignmentCommand}" Classes="apply"/> 
                    </Grid>

                    <StackPanel Spacing="10" IsVisible="{Binding IsProcessingVisible}">
                        <TextBlock Text="{Binding ProcessingStatusText}" HorizontalAlignment="Center" Foreground="#CCCCCC" FontStyle="Italic"/>
                        <ProgressBar IsIndeterminate="True" Height="4" HorizontalAlignment="Stretch" Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/> 
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ToolWindowBackgroundBrush}" Padding="10">
            <Border Name="PreviewBorder" Background="{DynamicResource ToolPreviewBackgroundBrush}" ClipToBounds="True" 
                    PointerPressed="OnPreviewPointerPressed" PointerReleased="OnPreviewPointerReleased" PointerMoved="OnPreviewPointerMoved" PointerWheelChanged="OnPreviewPointerWheelChanged" SizeChanged="OnPreviewSizeChanged"> 
                <Grid>
                    <Canvas Name="Viewport" RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Viewport.Scale}" ScaleY="{Binding Viewport.Scale}"/>
                                <TranslateTransform X="{Binding Viewport.OffsetX}" Y="{Binding Viewport.OffsetY}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                        
                        <Image Name="PreviewImage" Source="{Binding ActiveRenderer.Image}" Stretch="None" RenderOptions.BitmapInterpolationMode="None" Canvas.Left="0" Canvas.Top="0"/>
                        <Canvas Name="InteractionCanvas" Background="Transparent" 
                                Width="{Binding ActiveRenderer.ImageSize.Width}" Height="{Binding ActiveRenderer.ImageSize.Height}" 
                                Canvas.Left="0" Canvas.Top="0" 
                                PointerPressed="OnInteractionCanvasPointerPressed"
                                IsHitTestVisible="{Binding IsTargetPlacementAllowed}"/>
                    </Canvas>

                    <Canvas Name="TargetOverlayCanvas" IsHitTestVisible="False">
                        <Rectangle Stroke="{DynamicResource OverlaySearchBoxBrush}" StrokeThickness="1" StrokeDashArray="2,2" 
                                   Canvas.Left="{Binding Viewport.SearchBoxLeft}" Canvas.Top="{Binding Viewport.SearchBoxTop}" 
                                   Width="{Binding Viewport.SearchBoxWidth}" Height="{Binding Viewport.SearchBoxHeight}"
                                   IsVisible="{Binding IsSearchBoxOverlayVisible}"/>
                        
                        <Path Data="M0,10 L20,10 M10,0 L10,20" Stroke="{DynamicResource OverlayTargetMarkerBrush}" StrokeThickness="1"
                              Canvas.Left="{Binding Viewport.TargetMarkerScreenX}" Canvas.Top="{Binding Viewport.TargetMarkerScreenY}"
                              IsVisible="{Binding Viewport.IsTargetMarkerVisible}">
                            <Path.RenderTransform><TranslateTransform X="-10" Y="-10" /></Path.RenderTransform>
                        </Path>
                    </Canvas>

                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="8,4" Background="{DynamicResource OverlayTextBackgroundBrush}" CornerRadius="4" IsHitTestVisible="False">
                        <TextBlock Text="{Binding Viewport.Scale, StringFormat={}{0:P0}}" Foreground="{DynamicResource OverlayTextForegroundBrush}" FontSize="14"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" ZIndex="1" Background="Transparent" PointerPressed="OnControlsPointerPressed"> 
                        <Button Name="ZoomOutButton" ToolTip.Tip="Zoom Out"><avalonia:MaterialIcon Kind="Minus" Width="16" Height="16" /></Button>
                        <Button Name="ZoomInButton" ToolTip.Tip="Zoom In"><avalonia:MaterialIcon Kind="Plus" Width="16" Height="16" /></Button>
                        <Button Name="ResetViewButton" Margin="8,0,0,0" ToolTip.Tip="Reset Vista"><avalonia:MaterialIcon Kind="FitToScreen" Width="16" Height="16" /></Button>
                        <Path Data="M0,0 V18" Stroke="#666666" StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
                        <Button Name="ResetThresholdsButton" ToolTip.Tip="Reset Stretch" Command="{Binding ResetThresholdsCommand}"><avalonia:MaterialIcon Kind="Contrast" Width="16" Height="16" /></Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" 
                                HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                                ZIndex="1" Background="Transparent" 
                                PointerPressed="OnControlsPointerPressed" 
                                IsVisible="{Binding IsNavigationVisible}">
    
                        <Button Name="GoToFirstImageButton" Command="{Binding Navigator.MoveToFirstCommand}" ToolTip.Tip="Prima Immagine">
                            <avalonia:MaterialIcon Kind="ChevronDoubleLeft" Width="16" Height="16" />
                        </Button>

                        <Button Name="PreviousImageButton" Command="{Binding Navigator.PreviousCommand}" ToolTip.Tip="Precedente">
                            <avalonia:MaterialIcon Kind="ChevronLeft" Width="16" Height="16" />
                        </Button>
    
                        <TextBlock Text="{Binding CurrentImageText}" VerticalAlignment="Center" Margin="8,0" Foreground="White" FontWeight="Bold"/>
    
                        <Button Name="NextImageButton" Command="{Binding Navigator.NextCommand}" ToolTip.Tip="Successiva">
                            <avalonia:MaterialIcon Kind="ChevronRight" Width="16" Height="16" />
                        </Button>

                        <Button Name="GoToLastImageButton" Command="{Binding Navigator.MoveToLastCommand}" ToolTip.Tip="Ultima Immagine">
                            <avalonia:MaterialIcon Kind="ChevronDoubleRight" Width="16" Height="16" />
                        </Button>
    
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>