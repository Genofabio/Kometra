<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KomaLab.ViewModels"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:converters="clr-namespace:KomaLab.Converters"
        xmlns:models="clr-namespace:KomaLab.Models"
        xmlns:av="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
        xmlns:processing="clr-namespace:KomaLab.Models.Processing"
        xmlns:tools="clr-namespace:KomaLab.ViewModels.Tools"
        xmlns:items="clr-namespace:KomaLab.ViewModels.Items"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="KomaLab.Views.AlignmentToolView"
        x:DataType="tools:AlignmentToolViewModel"
        Title="Allineamento"
        Width="800" Height="600"
        MinHeight="500" MinWidth="710"
        WindowStartupLocation="CenterScreen"
        Loaded="OnWindowLoaded"
        Focusable="True">

    <Window.Resources>
        <converters:EqualityConverter x:Key="EqualityConverter" />
        <converters:AlignmentModeNameConverter x:Key="AlignmentModeNameConverter" />
        <converters:EnumToBoolConverter x:Key="EnumToBool" />
        
        <DataTemplate x:Key="CoordinateItemTemplate"
                      x:DataType="items:CoordinateEntry">
            
            <Border Classes="CoordinateEntryRow"
                    Classes.active="{Binding IsActive}">
                
                <Grid ColumnDefinitions="40, *, *"> 
                    <Border Grid.Column="0" 
                            Background="{DynamicResource ActionPrimaryBackgroundBrush}"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch">
                        <TextBlock Text="{Binding DisplayIndex}" 
                                   Foreground="White"
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,6">
                            <TextBlock Text="X" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="11" VerticalAlignment="Bottom" Opacity="0.7"/>
                            <TextBlock Text="{Binding FormattedX}" FontWeight="SemiBold" FontSize="13" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,6">
                        <TextBlock Text="Y" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="11" VerticalAlignment="Bottom" Opacity="0.7"/>
                        <TextBlock Text="{Binding FormattedY}" FontWeight="SemiBold" FontSize="13" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="/Styles/AlignmentToolStyles.axaml" />
    </Window.Styles>
    
    <Grid ColumnDefinitions="300, *">
        
        <Border Grid.Column="0" 
                Background="{DynamicResource ToolPanelBackgroundBrush}" 
                Padding="15" 
                IsEnabled="{Binding IsInteractionEnabled}">
            
            <Grid RowDefinitions="Auto, *, Auto">
                
                <StackPanel Grid.Row="0" Spacing="10">
                    
                    <StackPanel x:Name="SetupContainer" Spacing="10" IsVisible="{Binding !IsCoordinateListVisible}">
                        
                        <StackPanel Spacing="12">
                            <TextBlock Text="Oggetto dell'allineamento" 
                                       FontSize="16" FontWeight="Bold" />
                            
                            <Grid ColumnDefinitions="*,*">
                                <RadioButton Grid.Column="0" GroupName="TargetGroup" Content="Cometa" Classes="segmented" CornerRadius="4,0,0,4" BorderThickness="1,1,0,1" HorizontalAlignment="Stretch"
                                             IsChecked="{Binding SelectedTarget, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static processing:AlignmentTarget.Comet}}" />
                                <RadioButton Grid.Column="1" GroupName="TargetGroup" Content="Stelle" Classes="segmented" CornerRadius="0,4,4,0" BorderThickness="1" HorizontalAlignment="Stretch"
                                             IsChecked="{Binding SelectedTarget, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static processing:AlignmentTarget.Stars}}" />
                            </Grid>
                            <Separator Margin="0,5,0,5"/>
                        </StackPanel>

                        <StackPanel Spacing="12" IsVisible="{Binding SelectedTarget, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static processing:AlignmentTarget.Comet}}">
                            <TextBlock Text="Metodologia" FontSize="16" FontWeight="Bold" />
                            <ComboBox ItemsSource="{Binding AvailableAlignmentModes}" SelectedItem="{Binding SelectedMode}" HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding ., Converter={StaticResource AlignmentModeNameConverter}}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            
                            <Panel MinHeight="40">
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" IsVisible="{Binding SelectedMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Automatic}"><Run>Rilevamento automatico del nucleo della cometa. </Run></TextBlock>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" IsVisible="{Binding SelectedMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Guided}"><Run>Indica il nucleo sulla prima e ultima immagine.</Run></TextBlock>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" IsVisible="{Binding SelectedMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Manual}"><Run>Ispeziona e imposta manualmente il centro per ogni immagine.</Run></TextBlock>
                            </Panel>
                            <Separator Margin="0,5,0,0"/> 
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <StackPanel.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                    <Binding Path="IsSearchRadiusControlsVisible"/>
                                    <Binding Path="IsJplOptionVisible"/>
                                </MultiBinding>
                            </StackPanel.IsVisible>
                        
                            <TextBlock Text="Opzioni di Ricerca" FontSize="14" FontWeight="Bold" />

                            <StackPanel IsVisible="{Binding IsJplOptionVisible}" Spacing="2">
                                <CheckBox IsChecked="{Binding UseJplAstrometry}" Content="{Binding AstrometryOptionLabel}" Margin="0" ToolTip.Tip="Usa dati orbitali o astrometrici (WCS) per l'allineamento"/>
                                <StackPanel IsVisible="{Binding UseJplAstrometry}">
                                    <Grid ColumnDefinitions="*, Auto" Margin="0,5,0,5" IsVisible="{Binding IsTargetNameInputVisible}">
                                        <TextBox Grid.Column="0" Text="{Binding TargetName}" Watermark="Nome (es. 67P)" Margin="0,0,5,0"/>
                                        <Button Grid.Column="1" Command="{Binding VerifyJplCommand}" ToolTip.Tip="Verifica disponibilità dati" IsVisible="{Binding IsVerifyButtonVisible}">
                                            <StackPanel Orientation="Horizontal" Spacing="5"><avalonia:MaterialIcon Kind="LinkVariant" Width="16" Height="16"/><TextBlock Text="Verifica"/></StackPanel>
                                        </Button>
                                    </Grid>
                                    <StackPanel Spacing="2">
                                        <ProgressBar IsIndeterminate="True" Height="2" IsVisible="{Binding IsVerifyingJpl}" Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/>
                                        <TextBlock Text="{Binding AstrometryStatusMessage}" FontSize="11" Foreground="{Binding AstrometryStatusBrush}" TextWrapping="Wrap" Margin="2,0,0,0" IsVisible="{Binding AstrometryStatusMessage, Converter={x:Static av:StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="5" IsVisible="{Binding IsSearchRadiusControlsVisible}">
                                <StackPanel Spacing="5" Margin="0,5,0,0">
                                    <TextBlock Text="Raggio di Ricerca (px):" Background="Transparent"/> 
                                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                        <TextBox Grid.Column="0" Name="SearchRadiusTextBox" Text="{Binding SearchRadius, Mode=OneWay}" MinWidth="45" VerticalAlignment="Center" HorizontalContentAlignment="Right" GotFocus="OnSearchRadiusTextBoxGotFocus" LostFocus="OnSearchRadiusTextBoxLostFocus"/>
                                        <Slider Grid.Column="1" Minimum="{Binding MinSearchRadius}" Maximum="{Binding MaxSearchRadius}" Value="{Binding SearchRadius}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Spacing="5" IsVisible="{Binding IsCoordinateListVisible}">
                        <TextBlock Text="Rifinitura Manuale" FontSize="16" FontWeight="Bold"/>
                        <TextBlock TextWrapping="Wrap" Opacity="0.7" Margin="0,6,0,0"><Run>I centri sono stati calcolati. Clicca sull'immagine per modificare manualmente la posizione.</Run></TextBlock>
                        
                        <Separator Margin="0,9, 0, 8"/>
                        <TextBlock Text="Centri Rilevati" FontWeight="SemiBold" Margin="0,5,0,8"/>
                    </StackPanel>
                </StackPanel>
                
                <ScrollViewer Grid.Row="1" Padding="0,0,16,0" Margin="0,5,0,0" VerticalScrollBarVisibility="Auto" IsEnabled="{Binding IsInteractionEnabled}" IsVisible="{Binding IsCoordinateListVisible}">
                    <ItemsControl ItemsSource="{Binding CoordinateEntries}" ItemTemplate="{StaticResource CoordinateItemTemplate}"/>
                </ScrollViewer>
                
                <StackPanel Grid.Row="2" Spacing="10" Margin="0,15,0,0">
                    <Separator Margin="0,5,0,10"/>
                    <Button Content="Calcola Centri" Command="{Binding CalculateCentersCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" IsVisible="{Binding IsCalculateButtonVisible}" IsEnabled="{Binding IsInteractionEnabled}" Classes="calculate"/> 
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" IsVisible="{Binding IsApplyCancelButtonsVisible}" IsEnabled="{Binding IsInteractionEnabled}">
                        <Button Grid.Column="0" Content="Annulla" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding CancelCalculationCommand}" Classes="cancel"/> 
                        <Button Grid.Column="1" Content="Applica" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding ApplyAlignmentCommand}" Classes="apply"/> 
                    </Grid>
                    <StackPanel Spacing="10" IsVisible="{Binding IsProcessingVisible}">
                        <TextBlock Text="{Binding ProcessingStatusText}" HorizontalAlignment="Center" Foreground="#CCCCCC" FontStyle="Italic"/>
                        <ProgressBar IsIndeterminate="True" Height="4" HorizontalAlignment="Stretch" Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/> 
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ToolWindowBackgroundBrush}" Padding="10">
            <Border Name="PreviewBorder" Background="{DynamicResource ToolPreviewBackgroundBrush}" ClipToBounds="True" PointerPressed="OnPreviewPointerPressed" PointerReleased="OnPreviewPointerReleased" PointerMoved="OnPreviewPointerMoved" PointerWheelChanged="OnPreviewPointerWheelChanged" SizeChanged="OnPreviewSizeChanged"> 
                <Grid>
                    <Canvas Name="Viewport" RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Viewport.Scale}" ScaleY="{Binding Viewport.Scale}"/>
                                <TranslateTransform X="{Binding Viewport.OffsetX}" Y="{Binding Viewport.OffsetY}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                        <Image Name="PreviewImage" Source="{Binding ActiveImage.Image}" Stretch="None" RenderOptions.BitmapInterpolationMode="None" Canvas.Left="0" Canvas.Top="0"/>
                        <Canvas Name="InteractionCanvas" Background="Transparent" Width="{Binding ActiveImage.ImageSize.Width}" Height="{Binding ActiveImage.ImageSize.Height}" Canvas.Left="0" Canvas.Top="0" PointerPressed="OnInteractionCanvasPointerPressed"/>
                    </Canvas>
                    <Canvas Name="TargetOverlayCanvas" IsHitTestVisible="False">
                        <Rectangle Stroke="{DynamicResource OverlaySearchBoxBrush}" StrokeThickness="1" StrokeDashArray="2,2" Canvas.Left="{Binding Viewport.SearchBoxLeft}" Canvas.Top="{Binding Viewport.SearchBoxTop}" Width="{Binding Viewport.SearchBoxWidth}" Height="{Binding Viewport.SearchBoxHeight}">
                            <Rectangle.IsVisible><Binding Path="IsSearchBoxVisible" /></Rectangle.IsVisible>
                        </Rectangle>
                        <Path Data="M0,10 L20,10 M10,0 L10,20" Stroke="{DynamicResource OverlayTargetMarkerBrush}" StrokeThickness="1">
                            <Path.IsVisible><Binding Path="IsTargetMarkerVisible" /></Path.IsVisible>
                            <Canvas.Left><Binding Path="Viewport.TargetMarkerScreenX" /></Canvas.Left>
                            <Canvas.Top><Binding Path="Viewport.TargetMarkerScreenY" /></Canvas.Top>
                            <Path.RenderTransform><TranslateTransform X="-10" Y="-10" /></Path.RenderTransform>
                        </Path>
                    </Canvas>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="8,4" Background="{DynamicResource OverlayTextBackgroundBrush}" CornerRadius="4" IsHitTestVisible="False">
                        <TextBlock Text="{Binding ZoomStatusText}" Foreground="{DynamicResource OverlayTextForegroundBrush}" FontSize="14"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" ZIndex="1" Background="Transparent" PointerPressed="OnControlsPointerPressed" IsEnabled="{Binding IsInteractionEnabled}"> 
                        <Button Name="ZoomOutButton" ToolTip.Tip="Zoom Out"><avalonia:MaterialIcon Kind="Minus" Width="16" Height="16" /></Button>
                        <Button Name="ZoomInButton" ToolTip.Tip="Zoom In"><avalonia:MaterialIcon Kind="Plus" Width="16" Height="16" /></Button>
                        <Button Name="ResetViewButton" Margin="8,0,0,0" ToolTip.Tip="Reset View (Zoom &amp; Pan)"><avalonia:MaterialIcon Kind="FitToScreen" Width="16" Height="16" /></Button>
                        <Path Data="M0,0 V18" Stroke="#666666" StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
                        <Button Name="ResetThresholdsButton" ToolTip.Tip="Reset Stretch (Livelli)" Command="{Binding ResetThresholdsCommand}"><avalonia:MaterialIcon Kind="Contrast" Width="16" Height="16" /></Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" ZIndex="1" Classes="NavControls" IsVisible="{Binding IsNavigationVisible}" IsEnabled="{Binding IsInteractionEnabled}" Background="Transparent" PointerPressed="OnControlsPointerPressed">
                        <Button Name="GoToFirstImageButton" ToolTip.Tip="Prima Immagine" Command="{Binding GoToFirstImageCommand}"><avalonia:MaterialIcon Kind="ChevronDoubleLeft" Width="16" Height="16" /></Button>
                        <Button Name="PreviousImageButton" ToolTip.Tip="Immagine Precedente" Command="{Binding PreviousImageCommand}"><avalonia:MaterialIcon Kind="ChevronLeft" Width="16" Height="16" /></Button>
                        <TextBlock Text="{Binding StackCounterText}" />
                        <Button Name="NextImageButton" ToolTip.Tip="Immagine Successiva" Command="{Binding NextImageCommand}"><avalonia:MaterialIcon Kind="ChevronRight" Width="16" Height="16" /></Button>
                        <Button Name="GoToLastImageButton" ToolTip.Tip="Ultima Immagine" Command="{Binding GoToLastImageCommand}"><avalonia:MaterialIcon Kind="ChevronDoubleRight" Width="16" Height="16" /></Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>