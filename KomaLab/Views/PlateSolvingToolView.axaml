<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:tools="clr-namespace:KomaLab.ViewModels.Tools"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="KomaLab.Views.PlateSolvingToolView"
        x:DataType="tools:PlateSolvingToolViewModel"
        x:Name="RootWindow"
        
        Title="Risoluzione Astrometrica"
        Width="650" Height="550"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource ToolWindowBackgroundBrush}"
        Focusable="True">

    <Window.Styles>
        <StyleInclude Source="/Styles/PlateSolvingToolStyles.axaml" />
    </Window.Styles>

    <Border Padding="20" Background="Transparent">
        <Grid RowDefinitions="Auto, Auto, *, Auto" RowSpacing="15">

            <StackPanel Grid.Row="0" Spacing="10">
                <TextBlock Classes="TitleText" Text="{Binding Title}"/>
                
                <TextBlock Classes="DescriptionText" 
                           Text="Analizza la disposizione delle stelle per calcolare le coordinate celesti reali (WCS). Questa operazione è necessaria per l'allineamento preciso."/>

                <Border Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,5"/>

                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Classes="TargetLabel" Text="Target:"/>
                    <TextBlock Classes="TargetValue" Text="{Binding TargetFileName}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="8">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="{Binding ProgressValue, StringFormat='Processati: {0}'}" 
                               Foreground="{DynamicResource Text.MediumGreyBrush}" 
                               FontSize="12" IsVisible="{Binding IsBusy}" Grid.Column="1"/>
                </Grid>
                
                <ProgressBar Height="6" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                             IsIndeterminate="{Binding ProgressMax, Converter={x:Static ObjectConverters.IsNull}}"
                             IsVisible="{Binding IsBusy}" 
                             Foreground="{DynamicResource ActionPrimaryBackgroundBrush}" 
                             Background="{DynamicResource MenuBackgroundBrush}"/>
            </StackPanel>

            <Border Grid.Row="2" Classes="LogContainer">
                <TextBox Classes="LogContent"
                         Text="{Binding FullLog}" 
                         IsReadOnly="True" 
                         CaretIndex="{Binding FullLog.Length}"/>
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="*, Auto">
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <avalonia:MaterialIcon Kind="AlertCircleOutline" Width="16" Height="16" Foreground="{DynamicResource OverlaySearchBoxBrush}"/>
                        <TextBlock Classes="WarningLabel" Text="Attenzione:"/>
                    </StackPanel>
                    
                    <TextBlock Classes="WarningBody" Text="L'header originale verrà aggiornato."/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <Button Classes="baseBtn greenBtn" 
                            Command="{Binding StartSolvingCommand}"
                            Content="Avvia risoluzione">
                        <Button.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsBusy"/>
                                <Binding Path="!IsFinished"/>
                            </MultiBinding>
                        </Button.IsVisible>
                    </Button>

                    <Button Classes="baseBtn cancelBtn" 
                            Command="{Binding CancelOperationCommand}"
                            IsVisible="{Binding IsBusy}"
                            Content="Annulla"/>

                    <Button Classes="baseBtn purpleBtn" 
                            Command="{Binding CloseWindowCommand}"
                            CommandParameter="{Binding ElementName=RootWindow}"
                            IsVisible="{Binding IsFinished}"
                            Content="Chiudi finestra"/>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>