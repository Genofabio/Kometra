<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:astrometry="clr-namespace:KomaLab.ViewModels.Astrometry"
        mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="550"
        x:Class="KomaLab.Views.PlateSolvingToolView"
        x:DataType="astrometry:PlateSolvingToolViewModel"
        x:Name="RootWindow"
        Title="Risoluzione Astrometrica"
        Width="650" Height="550"
        MinWidth="650" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource ToolWindowBackgroundBrush}">

    <Border Padding="20" Background="Transparent">
        <Grid RowDefinitions="Auto, Auto, *, Auto" RowSpacing="15">

            <StackPanel Grid.Row="0" Spacing="10">
                <TextBlock Classes="TitleText" Text="{Binding Title}"/>
                <TextBlock Classes="DescriptionText" 
                           Text="Analizza la disposizione delle stelle per calcolare le coordinate celesti reali (WCS)."/>
                <Border Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,5"/>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Classes="TargetLabel" Text="Target:"/>
                    <TextBlock Classes="TargetValue" Text="{Binding TargetName}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="8">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="{Binding ProgressValue, StringFormat='Processati: {0}'}" 
                               Foreground="{DynamicResource Text.MediumGreyBrush}" 
                               FontSize="12" IsVisible="{Binding IsBusyState}" Grid.Column="1"/>
                </Grid>
                <ProgressBar Height="6" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                             IsVisible="{Binding IsBusyState}" 
                             Foreground="{DynamicResource ActionPrimaryBackgroundBrush}" 
                             Background="{DynamicResource MenuBackgroundBrush}"/>
            </StackPanel>

            <Border Grid.Row="2" Classes="LogContainer">
                <TextBox Classes="LogContent"
                         Text="{Binding FullLog}" 
                         IsReadOnly="True" 
                         CaretIndex="{Binding FullLog.Length}"/>
            </Border>

            <StackPanel Grid.Row="3" Spacing="15">
                
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <avalonia:MaterialIcon Kind="AlertCircleOutline" Width="16" Height="16" 
                                           Foreground="{DynamicResource OverlaySearchBoxBrush}"/>
                    <TextBlock Classes="WarningLabel" Text="Attenzione:" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Classes="WarningBody" Margin="0"
                               Text="Applica i risultati per rendere le modifiche all'header permanenti." 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                                IsVisible="{Binding IsInitialState}">
                        <Button Classes="baseBtn calculate" 
                                Command="{Binding StartSolvingCommand}"
                                Content="Avvia risoluzione"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                                IsVisible="{Binding IsBusyState}">
                        <Button Classes="baseBtn cancel" 
                                Command="{Binding CancelCommand}"
                                Content="Interrompi"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" 
                                IsVisible="{Binding IsFinishedState}">
        
                        <Button Classes="baseBtn calculate" 
                                Command="{Binding StartSolvingCommand}"
                                Content="Riavvia risoluzione"/>

                        <Button Classes="baseBtn cancel" 
                                Command="{Binding CloseCommand}"
                                Content="Annulla"/>

                        <Button Classes="baseBtn apply" 
                                Command="{Binding ApplyResultsCommand}"
                                Content="Applica"
                                IsEnabled="{Binding CanApply}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
            
        </Grid>
    </Border>
</Window>