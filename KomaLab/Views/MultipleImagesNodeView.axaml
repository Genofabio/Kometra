<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:KomaLab.ViewModels"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:conv="clr-namespace:KomaLab.Converters"
             mc:Ignorable="d" 
             x:Class="KomaLab.Views.MultipleImagesNodeView"
             x:DataType="vm:MultipleImagesNodeViewModel"
             d:DesignWidth="300" d:DesignHeight="250"
             PointerPressed="OnPointerPressed"
             PointerReleased="OnPointerReleased"
             PointerMoved="OnPointerMoved"
             PointerWheelChanged="OnPointerWheelChanged">
    
    <UserControl.Resources>
        <conv:NodeCategoryConverter x:Key="CatToClassConv" />
    </UserControl.Resources>
    
    <UserControl.Styles>
        
        <Style Selector="Button.NavButton">
            <Setter Property="Background" Value="#544869"/>
            <Setter Property="Foreground" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="Button.NavButton avalonia|MaterialIcon">
            <Setter Property="FontSize" Value="24"/> 
        </Style>
        
        <Style Selector="Button.NavButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#6B5C85"/> 
            <Setter Property="Foreground" Value="White"/>     
        </Style>
        
        <Style Selector="Grid#OverlayGrid">
            <Setter Property="Opacity" Value="0.0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0.2"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Border#ImageBorder:pointerover Grid#OverlayGrid">
            <Setter Property="Opacity" Value="1.0"/>
        </Style>
        
    </UserControl.Styles>

    <Border Classes="NodeFrame" 
            Classes.selected="{Binding IsSelected}"
            Tag="{Binding Category, Converter={StaticResource CatToClassConv}}"
            CornerRadius="8,8,8,8">
        
        <Grid RowDefinitions="Auto, *">
            
            <Border Grid.Row="0" 
                    Classes="Header"
                    CornerRadius="8,0,0,0" 
                    ClipToBounds="True">
                
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Title}" 
                               FontWeight="Normal" 
                               FontSize="30" 
                               HorizontalAlignment="Left" VerticalAlignment="Center"
                               Padding="18"
                               TextTrimming="CharacterEllipsis"/>
                    
                    <Button Grid.Column="1" 
                            Content="✕" 
                            Classes="CloseButton"
                            Command="{Binding RemoveSelfCommand}"
                            
                            FontSize="24"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            
                            CornerRadius="0"
                            BorderThickness="0"
                            
                            Margin="0,-1,-1,0"
                            Padding="0,4,0,0"
                            
                            Width="{Binding $self.Bounds.Height}"/>
                </Grid>
            </Border>
            
            <Border Grid.Row="1" Background="#2C2C2C" Name="ImageBorder"
                    CornerRadius="0,0,8,8" ClipToBounds="True"
                    Width="{Binding MaxImageSize.Width}"
                    Height="{Binding MaxImageSize.Height}">
                
                <Grid>
                    <Image Source="{Binding ActiveFitsImage.Image}"
                           Stretch="None" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapInterpolationMode="LowQuality"/>
                    
                    <Grid Name="OverlayGrid">
                        
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="#B3353040" Margin="0,10,10,0"
                                CornerRadius="4" ClipToBounds="True">
                            
                            <TextBlock Text="{Binding CurrentImageText}"
                                       Foreground="White" Padding="12,8" Margin="12,8"
                                       FontSize="32"/> 
                        </Border>
                        
                        <Button Classes="NavButton" 
                                HorizontalAlignment="Left" VerticalAlignment="Center" 
                                Margin="10,10"
                                Padding="14,16,18,16"
                                CornerRadius="4"
                                Command="{Binding PreviousImageCommand}"
                                IsVisible="{Binding CanShowPrevious}">
                            <avalonia:MaterialIcon Kind="ChevronLeft" />
                        </Button>
                        
                        <Button Classes="NavButton" 
                                HorizontalAlignment="Right" VerticalAlignment="Center" 
                                Margin="10,10"
                                Padding="18,16,14,16"
                                CornerRadius="4"
                                Command="{Binding NextImageCommand}"
                                IsVisible="{Binding CanShowNext}">
                            <avalonia:MaterialIcon Kind="ChevronRight" />
                        </Button>
                    </Grid>
                    
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>