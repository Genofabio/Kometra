<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KomaLab.ViewModels"
             x:Class="KomaLab.Views.ConnectionView"
             x:DataType="vm:ConnectionViewModel"
             
             IsHitTestVisible="False"
             ClipToBounds="False"
             
             Width="0"  
             Height="0"> 
    
    <UserControl.Styles>
        <Style Selector="Path.ConnectionLine">
            <Setter Property="StrokeThickness" Value="8"/>
            <Setter Property="StrokeDashArray" Value="4,2"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Stroke" Duration="0:0:0.2"/>
                    <DoubleTransition Property="StrokeThickness" Duration="0:0:0.2"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Path.ConnectionLine.highlighted">
            <Setter Property="StrokeThickness" Value="10"/>
            <Setter Property="StrokeDashArray" Value="{x:Null}"/>
            <Setter Property="Opacity" Value="1.0"/>
        </Style>
    </UserControl.Styles>

    <Canvas>
        <Path Data="{Binding CurveGeometry}"
              Classes="ConnectionLine"
              Classes.highlighted="{Binding IsHighlighted}"
              Stroke="{Binding StrokeBrush}"
              Stretch="None" />
    </Canvas>

</UserControl>