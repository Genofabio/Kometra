<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:imageProcessing="clr-namespace:Kometra.ViewModels.ImageProcessing"
        xmlns:conv="clr-namespace:Kometra.Converters"
        xmlns:importExport="clr-namespace:Kometra.ViewModels.ImportExport"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="Kometra.Views.ImportView"
        x:DataType="importExport:ImportViewModel"
        Title="Importazione e Calibrazione Scientifica"
        Width="1000" Height="668"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ToolWindowBackgroundBrush}">

    <Window.Resources>
        <conv:IndexConverter x:Key="IndexConverter" />
        <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" FalseOpacity="0.35" />
    </Window.Resources>
    
    <Window.Styles>
        <StyleInclude Source="avares://Kometra/Styles/ImportStyles.axaml" />
    </Window.Styles>

    <Grid RowDefinitions="*, Auto">
        
        <Border Grid.Row="0" Padding="20" IsEnabled="{Binding IsInteractionEnabled}">
            <Grid RowDefinitions="Auto, *">
                
                <Grid Grid.Row="0" ColumnDefinitions="*, 25, 380" Margin="0,0,0,15">
                    <Border Grid.Column="0" BorderBrush="{DynamicResource Border.WhiteDimBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                        <TextBlock Text="1. IMMAGINI SORGENTE (LIGHTS)" FontWeight="Bold" Foreground="White" FontSize="16"/>
                    </Border>
                    <Border Grid.Column="2" BorderBrush="{DynamicResource Border.WhiteDimBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                        <TextBlock Text="2. CALIBRAZIONE" FontWeight="Bold" Foreground="White" FontSize="16"/>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*, 25, 380">
                    
                    <Grid Grid.Column="0" RowDefinitions="*, 15, Auto">
                        
                        <Border x:Name="LightsCard" Grid.Row="0" Background="{DynamicResource ToolPanelBackgroundBrush}" CornerRadius="4" Padding="12">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <TextBlock Grid.Row="0" Text="Immagini del Soggetto" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                
                                <Border Grid.Row="1" Background="{DynamicResource ToolWindowBackgroundBrush}" CornerRadius="4" BorderBrush="{DynamicResource Border.WhiteDimBrush}" BorderThickness="1">
                                    <ListBox ItemsSource="{Binding LightFiles}" Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="4,1">
                                                    <Grid ColumnDefinitions="14, *, 30">
                                                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Text.MediumGreyBrush}" FontSize="11" TextAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource IndexConverter}">
                                                                    <Binding Path="."/>
                                                                    <Binding Path="$parent[ListBox].ItemsSource"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        
                                                        <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" FontSize="11" 
                                                                 TextTrimming="PrefixCharacterEllipsis" Margin="18,0, 15, 0" Foreground="White"/>
                                                        
                                                        <Button Grid.Column="2" Classes="delBtn" Command="{Binding $parent[Window].((importExport:ImportViewModel)DataContext).RemoveLightCommand}" CommandParameter="{Binding}">
                                                            <avalonia:MaterialIcon Kind="Close" Width="10" Height="10"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,12,0,0">
                                    <Button Grid.Column="0" Content="Aggiungi immagine" Command="{Binding AddLightsCommand}" Classes="addPrimary" Margin="0,0,4,0"/>
                                    <Button Grid.Column="1" Content="Svuota " Command="{Binding ClearLightsCommand}" Classes="clearDestructive" Margin="4,0,0,0"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Background="{DynamicResource ToolPanelBackgroundBrush}" CornerRadius="4" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Opzioni di Importazione" FontSize="14" FontWeight="Bold"/>
                                
                                <CheckBox IsChecked="{Binding ImportAsSeparateNodes}" 
                                          Content="Importa come immagini separate"
                                          Foreground="{DynamicResource Text.MainGreyBrush}"
                                          ToolTip.Tip="Se attivo, crea un nodo indipendente per ogni immagine invece di raggrupparle in una sequenza."/>
                                
                                <TextBlock Text="Utile per analizzare singolarmente le estensioni di file mosaico o immagini indipendenti." 
                                           FontSize="10" Foreground="{DynamicResource Text.MediumGreyBrush}" 
                                           TextWrapping="Wrap" Margin="28,-18,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" 
                                 Opacity="{Binding HasLights, Converter={StaticResource BoolToOpacityConverter}}"
                                 IsEnabled="{Binding HasLights}">
                        <StackPanel Spacing="12">
                            <Border Background="{DynamicResource ToolPanelBackgroundBrush}" CornerRadius="4" Padding="12">
                                <Grid RowDefinitions="Auto, *, Auto">
                                    <TextBlock Grid.Row="0" Text="Bias Frames" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                    <Border Grid.Row="1" Background="{DynamicResource ToolWindowBackgroundBrush}" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource Border.WhiteDimBrush}">
                                        <ListBox Height="70" ItemsSource="{Binding BiasFiles}" Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="4,1">
                                                        <Grid ColumnDefinitions="8, *, 25">
                                                            <TextBlock Foreground="{DynamicResource Text.MediumGreyBrush}" FontSize="10" VerticalAlignment="Center" TextAlignment="Center">
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource IndexConverter}">
                                                                        <Binding Path="."/>
                                                                        <Binding Path="$parent[ListBox].ItemsSource"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="10" TextTrimming="PrefixCharacterEllipsis" VerticalAlignment="Center" Margin="14,0, 8,0"/>
                                                            <Button Grid.Column="2" Classes="delBtn" Height="18" Width="18" Command="{Binding $parent[Window].((importExport:ImportViewModel)DataContext).RemoveBiasCommand}" CommandParameter="{Binding}">
                                                                <avalonia:MaterialIcon Kind="Close" Width="8" Height="8"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                    <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,8,0,0">
                                        <Button Grid.Column="0" Content="Aggiungi Bias" Command="{Binding AddBiasCommand}" Classes="addPrimary" Margin="0,0,4,0"/>
                                        <Button Grid.Column="1" Content="Svuota" Command="{Binding ClearBiasCommand}" Classes="clearDestructive" Margin="4,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource ToolPanelBackgroundBrush}" CornerRadius="4" Padding="12">
                                <Grid RowDefinitions="Auto, *, Auto">
                                    <TextBlock Grid.Row="0" Text="Dark Frames" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                    <Border Grid.Row="1" Background="{DynamicResource ToolWindowBackgroundBrush}" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource Border.WhiteDimBrush}">
                                        <ListBox Height="70" ItemsSource="{Binding DarkFiles}" Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="4,1">
                                                        <Grid ColumnDefinitions="8, *, 25">
                                                            <TextBlock Foreground="{DynamicResource Text.MediumGreyBrush}" FontSize="10" VerticalAlignment="Center" TextAlignment="Center">
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource IndexConverter}">
                                                                        <Binding Path="."/>
                                                                        <Binding Path="$parent[ListBox].ItemsSource"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="10" TextTrimming="PrefixCharacterEllipsis" VerticalAlignment="Center" Margin="14,0,8,0"/>
                                                            <Button Grid.Column="2" Classes="delBtn" Height="18" Width="18" Command="{Binding $parent[Window].((importExport:ImportViewModel)DataContext).RemoveDarkCommand}" CommandParameter="{Binding}">
                                                                <avalonia:MaterialIcon Kind="Close" Width="8" Height="8"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                    <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,8,0,0">
                                        <Button Grid.Column="0" Content="Aggiungi Dark" Command="{Binding AddDarkCommand}" Classes="addPrimary" Margin="0,0,4,0"/>
                                        <Button Grid.Column="1" Content="Svuota" Command="{Binding ClearDarksCommand}" Classes="clearDestructive" Margin="4,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource ToolPanelBackgroundBrush}" CornerRadius="4" Padding="12">
                                <Grid RowDefinitions="Auto, *, Auto">
                                    <TextBlock Grid.Row="0" Text="Flat Fields" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                    <Border Grid.Row="1" Background="{DynamicResource ToolWindowBackgroundBrush}" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource Border.WhiteDimBrush}">
                                        <ListBox Height="70" ItemsSource="{Binding FlatFiles}" Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="4,1">
                                                        <Grid ColumnDefinitions="8, *, 25">
                                                            <TextBlock Foreground="{DynamicResource Text.MediumGreyBrush}" FontSize="10" VerticalAlignment="Center" TextAlignment="Center">
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource IndexConverter}">
                                                                        <Binding Path="."/>
                                                                        <Binding Path="$parent[ListBox].ItemsSource"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="10" TextTrimming="PrefixCharacterEllipsis" VerticalAlignment="Center" Margin="14,0,8,0"/>
                                                            <Button Grid.Column="2" Classes="delBtn" Height="18" Width="18" Command="{Binding $parent[Window].((importExport:ImportViewModel)DataContext).RemoveFlatCommand}" CommandParameter="{Binding}">
                                                                <avalonia:MaterialIcon Kind="Close" Width="8" Height="8"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                    <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,8,0,0">
                                        <Button Grid.Column="0" Content="Aggiungi Flat" Command="{Binding AddFlatCommand}" Classes="addPrimary" Margin="0,0,4,0"/>
                                        <Button Grid.Column="1" Content="Svuota" Command="{Binding ClearFlatsCommand}" Classes="clearDestructive" Margin="4,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource ToolPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource Border.WhiteDimBrush}" BorderThickness="0,1,0,0" 
                Padding="20,15" IsEnabled="{Binding IsInteractionEnabled}">
            <Grid ColumnDefinitions="*, Auto">
                
                <StackPanel VerticalAlignment="Center" IsVisible="{Binding IsProcessing}">
                    <TextBlock Text="{Binding StatusText}" FontSize="12" FontStyle="Italic" Margin="0,0,0,6"/>
                    <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6" Width="{Binding #LightsCard.Bounds.Width}" HorizontalAlignment="Left" Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <Button Content="Annulla" Command="{Binding CancelCommand}" Width="130" Classes="clearDestructive"/>
                    <Button Content="Applica e Importa" Command="{Binding ConfirmCommand}" Width="230" 
                            Classes="applySuccess"
                            IsEnabled="{Binding HasLights}"
                            Opacity="{Binding HasLights, Converter={StaticResource BoolToOpacityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>