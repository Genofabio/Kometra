<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:imageProcessing="clr-namespace:Kometra.ViewModels.ImageProcessing"
        xmlns:converters="clr-namespace:Kometra.Converters"
        xmlns:infrastructure="clr-namespace:Kometra.Infrastructure"
        xmlns:coordinators="clr-namespace:Kometra.Services.Processing.Coordinators"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="Kometra.Views.CropToolView"
        x:DataType="imageProcessing:CropToolViewModel"
        Icon="/Assets/Icon/icon32.ico"
        Title="{Binding [CropTitle], Source={x:Static infrastructure:LocalizationManager.Instance}}"
        Width="820" Height="600"
        MinHeight="550" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ToolWindowBackgroundBrush}"
        Focusable="True">

    <Window.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBool"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.description">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style Selector="TextBox.valueInput">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="RadioButton.segmented">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Text.MediumGreyBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border.WhiteDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,8"/> 
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/> 
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}" 
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.segmented:checked">
            <Setter Property="Background" Value="{DynamicResource ActionPrimaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ActionPrimaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="320, *">

        <Border Grid.Column="0" Background="{DynamicResource ToolPanelBackgroundBrush}" Padding="15">
            <Grid RowDefinitions="Auto, *, Auto">
                
                <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,15">
                    <TextBlock Text="{Binding [CropHeader], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                               FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <Border Height="1" Background="{DynamicResource Border.WhiteDimBrush}" Opacity="0.3" Margin="0,5"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="20">
                        
                        <StackPanel Spacing="8">
                            <StackPanel Spacing="0">
                                <TextBlock Classes="sectionTitle" Text="{Binding [CropModeTitle], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                <TextBlock Classes="description" Text="{Binding [CropModeDesc], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <RadioButton Grid.Column="0" GroupName="Mode" 
                                             Content="{Binding [CropModeStatic], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                                             Classes="segmented" CornerRadius="4,0,0,4" BorderThickness="1,1,0,1"
                                             IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static coordinators:CropMode.Static}}"
                                             ToolTip.Tip="{Binding [CropModeStaticTooltip], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                
                                <RadioButton Grid.Column="1" GroupName="Mode" 
                                             Content="{Binding [CropModeDynamic], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                                             Classes="segmented" CornerRadius="0,4,4,0" BorderThickness="1,1,1,1"
                                             IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static coordinators:CropMode.Dynamic}}"
                                             ToolTip.Tip="{Binding [CropModeDynamicTooltip], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                            </Grid>
                            
                            <TextBlock Text="{Binding InstructionsText}" 
                                       FontSize="11" Foreground="{DynamicResource Text.WarningBrush}" 
                                       TextWrapping="Wrap" Margin="0,2,0,0" FontStyle="Italic"/>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource Border.WhiteDimBrush}" Opacity="0.3" Margin="0,5"/>

                        <StackPanel Spacing="10">
                            <StackPanel Spacing="0">
                                <TextBlock Classes="sectionTitle" Text="{Binding [CropSizeTitle], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                <TextBlock Classes="description" Text="{Binding [CropSizeDesc], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding [CropWidth], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontSize="11" Foreground="{DynamicResource Text.MediumGreyBrush}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*, 75"> 
                                    <Slider Grid.Column="0" Minimum="10" Maximum="{Binding MaxAllowedWidth}" Value="{Binding CropWidth}" 
                                            IsSnapToTickEnabled="True" TickFrequency="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox Name="CropWidthBox" Grid.Column="1" Classes="valueInput" 
                                             Text="{Binding CropWidth, Mode=OneWay}" 
                                             LostFocus="OnValueInputLostFocus" KeyDown="OnInputKeyDown"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding [CropHeight], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontSize="11" Foreground="{DynamicResource Text.MediumGreyBrush}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*, 75">
                                    <Slider Grid.Column="0" Minimum="10" Maximum="{Binding MaxAllowedHeight}" Value="{Binding CropHeight}" 
                                            IsSnapToTickEnabled="True" TickFrequency="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox Name="CropHeightBox" Grid.Column="1" Classes="valueInput" 
                                             Text="{Binding CropHeight, Mode=OneWay}" 
                                             LostFocus="OnValueInputLostFocus" KeyDown="OnInputKeyDown"/>
                                </Grid>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,-5,0,0">
                                <TextBlock Text="{Binding [CropMaxAllowed], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                                           FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="{Binding MaxAllowedWidth}" 
                                           FontSize="10" Foreground="Gray" Margin="4,0,0,0"/>
                                <TextBlock Text=" x " FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="{Binding MaxAllowedHeight}" 
                                           FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="{Binding [CropFromSmallestFile], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                                           FontSize="10" Foreground="Gray" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Spacing="10" Margin="0,15,0,0">
                    <Border Height="1" Background="{DynamicResource Border.WhiteDimBrush}" Opacity="0.3" Margin="0,0,0,5"/>

                    <StackPanel Spacing="5" IsVisible="{Binding IsBusy}">
                        <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" FontSize="12" FontStyle="Italic" Foreground="{DynamicResource Text.MediumGreyBrush}"/>
                        <ProgressBar IsIndeterminate="True" Height="4" Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/>
                    </StackPanel>

                    <Button IsVisible="{Binding !IsBusy}" 
                            Content="{Binding [CropApply], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                            Command="{Binding ApplyCommand}" 
                            Background="{DynamicResource ActionSuccessBackgroundBrush}" 
                            Foreground="White"
                            Height="38"
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Center" 
                            VerticalContentAlignment="Center"
                            FontWeight="Bold" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ToolWindowBackgroundBrush}" Padding="10">
            <Border Name="PreviewBorder" Background="{DynamicResource ToolPreviewBackgroundBrush}" ClipToBounds="True"
                    PointerPressed="OnPreviewPointerPressed"
                    PointerReleased="OnPreviewPointerReleased"
                    PointerMoved="OnPreviewPointerMoved"
                    PointerWheelChanged="OnPreviewPointerWheelChanged"
                    SizeChanged="OnPreviewSizeChanged">
                <Grid>
                    <Canvas Name="Viewport" RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Viewport.Scale}" ScaleY="{Binding Viewport.Scale}"/>
                                <TranslateTransform X="{Binding Viewport.OffsetX}" Y="{Binding Viewport.OffsetY}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>

                        <Image Name="PreviewImage" Source="{Binding ActiveRenderer.Image}" Stretch="None" RenderOptions.BitmapInterpolationMode="None" Canvas.Left="0" Canvas.Top="0"/>
                    </Canvas>

                    <Canvas IsHitTestVisible="False" IsVisible="{Binding Viewport.IsCropVisible}">
                        
                        <Rectangle Canvas.Left="{Binding Viewport.ScreenRectX}"
                                   Canvas.Top="{Binding Viewport.ScreenRectY}"
                                   Width="{Binding Viewport.ScreenRectW}"
                                   Height="{Binding Viewport.ScreenRectH}"
                                   Stroke="{DynamicResource OverlaySearchBoxBrush}" 
                                   StrokeThickness="1" 
                                   Fill="#22FEC530"/> 
                        
                        <Line StartPoint="{Binding Viewport.ScreenRectCenterXLess10}" 
                              EndPoint="{Binding Viewport.ScreenRectCenterXPlus10}" 
                              Stroke="{DynamicResource OverlaySearchBoxBrush}" 
                              StrokeThickness="1.5"/>

                        <Line StartPoint="{Binding Viewport.ScreenRectCenterYLess10}" 
                              EndPoint="{Binding Viewport.ScreenRectCenterYPlus10}" 
                              Stroke="{DynamicResource OverlaySearchBoxBrush}" 
                              StrokeThickness="1.5"/>
                    </Canvas>

                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="8,4" Background="{DynamicResource OverlayTextBackgroundBrush}" CornerRadius="4" IsHitTestVisible="False">
                        <TextBlock Text="{Binding Viewport.Scale, StringFormat={}{0:P0}}" Foreground="{DynamicResource OverlayTextForegroundBrush}" FontSize="14"/>
                    </Border>
                    
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Padding="8,4" 
                            Background="{DynamicResource OverlayTextBackgroundBrush}" CornerRadius="4" IsHitTestVisible="False"
                            IsVisible="{Binding !Viewport.IsCropVisible}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <avalonia:MaterialIcon Kind="CursorDefaultClick" Foreground="{DynamicResource OverlayTextForegroundBrush}" Width="16" Height="16"/>
                            <TextBlock Text="{Binding [CropClickHint], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                                       Foreground="{DynamicResource OverlayTextForegroundBrush}" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" 
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                                ZIndex="1"
                                Background="Transparent" 
                                PointerPressed="OnControlsPointerPressed">
                        
                        <Button Command="{Binding SetCenterToImageMiddleCommand}" 
                                ToolTip.Tip="{Binding [TooltipCenterInterest], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="CrosshairsGps" Width="16" Height="16"/>
                        </Button>

                        <Path Data="M0,0 V18" Stroke="{DynamicResource ActionDisabledBackgroundBrush}" 
                              StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
    
                        <Button Click="OnZoomOutClicked" ToolTip.Tip="{Binding [TooltipZoomOut], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="Minus" Width="16" Height="16"/>
                        </Button>
    
                        <Button Click="OnZoomInClicked" ToolTip.Tip="{Binding [TooltipZoomIn], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                        </Button>
    
                        <Button Click="OnResetViewClicked" Margin="8,0,0,0" ToolTip.Tip="{Binding [TooltipResetView], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="FitToScreen" Width="16" Height="16"/>
                        </Button>
    
                        <Path Data="M0,0 V18" Stroke="{DynamicResource ActionDisabledBackgroundBrush}" 
                              StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
    
                        <Button Click="OnResetThresholdsClicked" ToolTip.Tip="{Binding [TooltipResetStretch], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="Contrast" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" 
                                HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                                ZIndex="1"
                                Background="Transparent"
                                PointerPressed="OnControlsPointerPressed"> 
    
                        <Button Command="{Binding Navigator.MoveToFirstCommand}" ToolTip.Tip="{Binding [TooltipFirstImage], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="ChevronDoubleLeft" Width="16" Height="16"/>
                        </Button>

                        <Button Command="{Binding Navigator.PreviousCommand}" ToolTip.Tip="{Binding [TooltipPrevImage], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="ChevronLeft" Width="16" Height="16"/>
                        </Button>

                        <TextBlock Text="{Binding CurrentImageText}" VerticalAlignment="Center" 
                                   Margin="8,0" Foreground="{DynamicResource Text.StaticWhiteBrush}" 
                                   FontWeight="SemiBold" FontSize="13"/>

                        <Button Command="{Binding Navigator.NextCommand}" ToolTip.Tip="{Binding [TooltipNextImage], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="ChevronRight" Width="16" Height="16"/>
                        </Button>

                        <Button Command="{Binding Navigator.MoveToLastCommand}" ToolTip.Tip="{Binding [TooltipLastImage], Source={x:Static infrastructure:LocalizationManager.Instance}}">
                            <avalonia:MaterialIcon Kind="ChevronDoubleRight" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>