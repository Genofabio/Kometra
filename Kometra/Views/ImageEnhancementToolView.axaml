<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:converters="clr-namespace:Kometra.Converters"
        xmlns:infrastructure="clr-namespace:Kometra.Infrastructure"
        xmlns:vm="clr-namespace:Kometra.ViewModels.ImageProcessing"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="Kometra.Views.ImageEnhancementToolView"
        x:DataType="vm:ImageEnhancementToolViewModel"
        Icon="/Assets/Icon/icon.ico"
        Width="900" Height="650" MinHeight="600" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ToolWindowBackgroundBrush}"
        Focusable="True">

    <Window.Title>
        <Binding Path="CurrentCategory">
            <Binding.Converter>
                <converters:EnhancementCategoryTitleConverter/>
            </Binding.Converter>
        </Binding>
    </Window.Title>

    <Window.Resources>
        <converters:EnhancementCategoryTitleConverter x:Key="TitleConverter" />
        <converters:ImageEnhancementModeConverter x:Key="ModeConverter" />
        <converters:ImageEnhancementDescriptionConverter x:Key="DescConverter" />
        <converters:EnumToBoolConverter x:Key="EnumToBool" />
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="/Styles/AlignmentToolStyles.axaml" />
        <Style Selector="TextBox.compact">
            <Setter Property="MinWidth" Value="65"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="12,0,0,0"/> 
        </Style>
        <Style Selector="TextBlock.labelInfo">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Help"/>
        </Style>
        <Style Selector="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,-4"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="380, *">
        
        <Border Grid.Column="0" Background="{DynamicResource ToolPanelBackgroundBrush}" Padding="15" IsEnabled="{Binding IsInteractionEnabled}">
            <Grid RowDefinitions="Auto, Auto, Auto, *, Auto, Auto">
                
                <TextBlock Grid.Row="0" Text="{Binding CurrentCategory, Converter={StaticResource TitleConverter}}" 
                           FontSize="20" FontWeight="Bold" Foreground="White" 
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" Spacing="8" IsEnabled="{Binding IsSetupControlsEnabled}">
                    <TextBlock Text="{Binding [EnhanceSelectedAlgorithm], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding AvailableModes}" 
                              SelectedItem="{Binding SelectedMode}" 
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ., Converter={StaticResource ModeConverter}}"/> 
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Border Grid.Row="2" Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,15"/>

                <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" IsEnabled="{Binding IsSetupControlsEnabled}">
                    <StackPanel Spacing="25">
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding [EnhanceDescription], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontSize="11" Opacity="0.5" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedMode, Converter={StaticResource DescConverter}}" 
                                       FontStyle="Italic" Opacity="0.8" TextWrapping="Wrap" FontSize="12"/>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsLarsonSekaninaVisible}">
                            <TextBlock Text="{Binding [EnhanceRotationParams], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceAngle], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceAngle], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="-45" Maximum="45" Value="{Binding RotationAngle}"/>
                                        <TextBox x:Name="RotationBox" Text="{Binding RotationAngle, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceShiftX], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceShiftX], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="-50" Maximum="50" Value="{Binding ShiftX}"/>
                                        <TextBox x:Name="ShiftXBox" Text="{Binding ShiftX, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceShiftY], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceShiftY], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="-50" Maximum="50" Value="{Binding ShiftY}"/>
                                        <TextBox x:Name="ShiftYBox" Text="{Binding ShiftY, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsAzimuthalContainerVisible}">
                            <TextBlock Text="{Binding [EnhancePolarGeometry], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                
                                <StackPanel Spacing="2" IsVisible="{Binding IsAngularQualityVisible}">
                                    <TextBlock Text="{Binding [EnhanceAngularQuality], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceAngularQuality], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="1" Maximum="20" Value="{Binding RadialSubsampling}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        <TextBox x:Name="SubsamplingBox" Text="{Binding RadialSubsampling, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="2" IsVisible="{Binding IsMaskRadiusVisible}">
                                    <TextBlock Text="{Binding [EnhanceMaskRadius], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceMaskRadius], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0" Maximum="2500" Value="{Binding RadialMaxRadius}"/>
                                        <TextBox x:Name="McmRadiusBox" Text="{Binding RadialMaxRadius, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="2" IsVisible="{Binding IsAzimuthalRejectionVisible}">
                                    <TextBlock Text="{Binding [EnhanceSigmaRejection], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceSigmaRejection], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.5" Maximum="10" Value="{Binding AzimuthalRejSigma}"/>
                                        <TextBox x:Name="AzimuthalRejBox" Text="{Binding AzimuthalRejSigma, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                
                                <StackPanel Spacing="2" IsVisible="{Binding IsAzimuthalNormVisible}">
                                    <TextBlock Text="{Binding [EnhanceNormScale], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceNormScale], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="20" Value="{Binding AzimuthalNormSigma}"/>
                                        <TextBox x:Name="AzimuthalNormBox" Text="{Binding AzimuthalNormSigma, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsRvsfSingleVisible}">
                            <TextBlock Text="{Binding [EnhanceRvsfSingleParams], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceParamA], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceParamA], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0" Maximum="1000" Value="{Binding RvsfA_1}"/>
                                        <TextBox x:Name="RvsfA1Box" Text="{Binding RvsfA_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceParamB], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceParamB], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0" Maximum="10" Value="{Binding RvsfB_1}"/>
                                        <TextBox x:Name="RvsfB1Box" Text="{Binding RvsfB_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceParamN], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceParamN], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="5" Value="{Binding RvsfN_1}"/>
                                        <TextBox x:Name="RvsfN1Box" Text="{Binding RvsfN_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <CheckBox Content="{Binding [EnhanceLogScale], Source={x:Static infrastructure:LocalizationManager.Instance}}" IsChecked="{Binding UseLogScale}" Margin="0,0,0,0"
                                          ToolTip.Tip="{Binding [TooltipEnhanceLogScale], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsRvsfMosaicVisible}">
                             <TextBlock Text="{Binding [EnhanceRvsfMosaicParams], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                             <StackPanel Spacing="8">
                                 <Grid ColumnDefinitions="*, 65, 30, 65">
                                    <TextBlock Text="{Binding [EnhanceIntervalA], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" VerticalAlignment="Center" ToolTip.Tip="{Binding [TooltipEnhanceIntervalA], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <TextBox x:Name="RvsfAMinBox" Grid.Column="1" Text="{Binding RvsfA_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    <TextBlock Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox x:Name="RvsfAMaxBox" Grid.Column="3" Text="{Binding RvsfA_2, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, 65, 30, 65">
                                    <TextBlock Text="{Binding [EnhanceIntervalB], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" VerticalAlignment="Center" ToolTip.Tip="{Binding [TooltipEnhanceIntervalB], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <TextBox x:Name="RvsfBMinBox" Grid.Column="1" Text="{Binding RvsfB_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    <TextBlock Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox x:Name="RvsfBMaxBox" Grid.Column="3" Text="{Binding RvsfB_2, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, 65, 30, 65">
                                    <TextBlock Text="{Binding [EnhanceIntervalN], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" VerticalAlignment="Center" ToolTip.Tip="{Binding [TooltipEnhanceIntervalN], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <TextBox x:Name="RvsfNMinBox" Grid.Column="1" Text="{Binding RvsfN_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    <TextBlock Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox x:Name="RvsfNMaxBox" Grid.Column="3" Text="{Binding RvsfN_2, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                </Grid>

                                <CheckBox Content="{Binding [EnhanceLogScale], Source={x:Static infrastructure:LocalizationManager.Instance}}" IsChecked="{Binding UseLogScale}" Margin="0,0,0,0"
                                          ToolTip.Tip="{Binding [TooltipEnhanceLogScaleSimple], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsFrangiVisible}">
                            <TextBlock Text="{Binding [EnhanceFrangiHeader], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceSigmaScale], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceSigmaScale], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.5" Maximum="20" Value="{Binding FrangiSigma}"/>
                                        <TextBox x:Name="FrangiSigmaBox" Text="{Binding FrangiSigma, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceBetaShape], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceBetaShape], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="2.0" Value="{Binding FrangiBeta}"/>
                                        <TextBox x:Name="FrangiBetaBox" Text="{Binding FrangiBeta, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceConstantC], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceConstantC], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.0001" Maximum="1.0" Value="{Binding FrangiC}"/>
                                        <TextBox x:Name="FrangiCBox" Text="{Binding FrangiC, Mode=OneWay, StringFormat={}{0:F4}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsTensorVisible}">
                            <TextBlock Text="{Binding [EnhanceTensorHeader], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceSigmaGradient], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceSigmaGradient], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="1" Maximum="15" Value="{Binding TensorSigma}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        <TextBox x:Name="TensorSigmaBox" Text="{Binding TensorSigma, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceRhoIntegration], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceRhoIntegration], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="1" Maximum="30" Value="{Binding TensorRho}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        <TextBox x:Name="TensorRhoBox" Text="{Binding TensorRho, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsTopHatVisible}">
                            <TextBlock Text="{Binding [EnhanceMorphologyHeader], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceKernelSize], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceTopHatKernel], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="3" Maximum="101" Value="{Binding TopHatKernelSize}" IsSnapToTickEnabled="True" TickFrequency="2"/>
                                        <TextBox x:Name="TopHatBox" Text="{Binding TopHatKernelSize, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsClaheVisible}">
                            <TextBlock Text="{Binding [EnhanceClaheHeader], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceClipLimit], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceClipLimit], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="40" Value="{Binding ClaheClipLimit}"/>
                                        <TextBox x:Name="ClaheClipBox" Text="{Binding ClaheClipLimit, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceGridSize], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceClaheGrid], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="2" Maximum="64" Value="{Binding ClaheTileSize}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        <TextBox x:Name="ClaheTileBox" Text="{Binding ClaheTileSize, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsLocalNormVisible}">
                            <TextBlock Text="{Binding [EnhanceLocalStatsHeader], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceWindowSize], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceLocalStatsWindow], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="3" Maximum="201" Value="{Binding LocalNormWindowSize}" IsSnapToTickEnabled="True" TickFrequency="2"/>
                                        <TextBox x:Name="LocalNormWindowBox" Text="{Binding LocalNormWindowSize, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceIntensity], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceLocalIntensity], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="10" Value="{Binding LocalNormIntensity}"/>
                                        <TextBox x:Name="LocalNormIntensityBox" Text="{Binding LocalNormIntensity, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsKernelVisible}">
                            <TextBlock Text="{Binding [EnhanceUnsharpHeader], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [EnhanceKernelSize], Source={x:Static infrastructure:LocalizationManager.Instance}}" Classes="labelInfo" ToolTip.Tip="{Binding [TooltipEnhanceKernelSize], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="3" Maximum="101" Value="{Binding KernelSize}" IsSnapToTickEnabled="True" TickFrequency="2"/>
                                        <TextBox x:Name="KernelSizeBox" Text="{Binding KernelSize, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="4" Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,15"/>

                <Panel Grid.Row="5">
                    <StackPanel Spacing="10" IsVisible="{Binding IsBusy}">
                        <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" FontSize="12" FontStyle="Italic"/>
                        <ProgressBar Value="{Binding ProgressValue}" 
                                     IsIndeterminate="{Binding ProgressValue, Converter={x:Static converters:ObjectConverters.IsZero}}" 
                                     Height="4" HorizontalAlignment="Stretch" 
                                     Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/>
                    </StackPanel>

                    <Button Content="{Binding [EnhanceCalcPreview], Source={x:Static infrastructure:LocalizationManager.Instance}}" Command="{Binding CalculatePreviewCommand}" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Classes="actionBtn calculate" IsVisible="{Binding IsCalculateButtonVisible}"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" IsVisible="{Binding IsApplyCancelButtonsVisible}">
                        <Button Grid.Column="0" Content="{Binding [EnhanceBack], Source={x:Static infrastructure:LocalizationManager.Instance}}" Command="{Binding CancelCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Classes="actionBtn cancel"/>
                        <Button Grid.Column="1" Content="{Binding [EnhanceApplyBatch], Source={x:Static infrastructure:LocalizationManager.Instance}}" Command="{Binding ApplyBatchCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Classes="actionBtn apply"/>
                    </Grid>
                </Panel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ToolWindowBackgroundBrush}" Padding="10">
            <Border Name="PreviewBorder" Background="{DynamicResource ToolPreviewBackgroundBrush}" ClipToBounds="True"
                    PointerPressed="OnPreviewPointerPressed" PointerReleased="OnPreviewPointerReleased" 
                    PointerMoved="OnPreviewPointerMoved" PointerWheelChanged="OnPreviewPointerWheelChanged">
                <Grid>
                    <Canvas Name="ViewportCanvas" RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Viewport.Scale}" ScaleY="{Binding Viewport.Scale}"/>
                                <TranslateTransform X="{Binding Viewport.OffsetX}" Y="{Binding Viewport.OffsetY}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                        <Image Source="{Binding ActiveRenderer.Image}" Stretch="None" RenderOptions.BitmapInterpolationMode="None"/>
                    </Canvas>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" 
                                HorizontalAlignment="Left" VerticalAlignment="Bottom" ZIndex="1" 
                                PointerPressed="OnControlsPointerPressed" IsEnabled="{Binding !IsBusy}">
                        <Button Command="{Binding Navigator.MoveToFirstCommand}" ToolTip.Tip="{Binding [TooltipFirstImage], Source={x:Static infrastructure:LocalizationManager.Instance}}"><avalonia:MaterialIcon Kind="ChevronDoubleLeft" Width="16" Height="16"/></Button>
                        <Button Command="{Binding Navigator.PreviousCommand}" ToolTip.Tip="{Binding [TooltipPrevImage], Source={x:Static infrastructure:LocalizationManager.Instance}}"><avalonia:MaterialIcon Kind="ChevronLeft" Width="16" Height="16"/></Button>
                        <TextBlock Text="{Binding CurrentImageText}" VerticalAlignment="Center" Margin="10,0" Foreground="White" FontWeight="Bold"/>
                        <Button Command="{Binding Navigator.NextCommand}" ToolTip.Tip="{Binding [TooltipNextImage], Source={x:Static infrastructure:LocalizationManager.Instance}}"><avalonia:MaterialIcon Kind="ChevronRight" Width="16" Height="16"/></Button>
                        <Button Command="{Binding Navigator.MoveToLastCommand}" ToolTip.Tip="{Binding [TooltipLastImage], Source={x:Static infrastructure:LocalizationManager.Instance}}"><avalonia:MaterialIcon Kind="ChevronDoubleRight" Width="16" Height="16"/></Button>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" ZIndex="1" PointerPressed="OnControlsPointerPressed">
                        <Button Click="OnZoomOutClicked" ToolTip.Tip="{Binding [TooltipZoomOut], Source={x:Static infrastructure:LocalizationManager.Instance}}"><avalonia:MaterialIcon Kind="Minus" Width="16" Height="16"/></Button>
                        <Button Click="OnZoomInClicked" ToolTip.Tip="{Binding [TooltipZoomIn], Source={x:Static infrastructure:LocalizationManager.Instance}}"><avalonia:MaterialIcon Kind="Plus" Width="16" Height="16"/></Button>
                        <Button Click="OnResetViewClicked" ToolTip.Tip="{Binding [TooltipFitView], Source={x:Static infrastructure:LocalizationManager.Instance}}"><avalonia:MaterialIcon Kind="FitToScreen" Width="16" Height="16"/></Button>
                        <Path Data="M0,0 V18" Stroke="#666666" StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
                        <Button Command="{Binding ResetThresholdsCommand}" ToolTip.Tip="{Binding [TooltipResetStretch], Source={x:Static infrastructure:LocalizationManager.Instance}}"><avalonia:MaterialIcon Kind="Contrast" Width="16" Height="16"/></Button>
                    </StackPanel>
                    
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="8,4" 
                            Background="{DynamicResource OverlayTextBackgroundBrush}" CornerRadius="4">
                        <TextBlock Text="{Binding Viewport.Scale, StringFormat={}{0:P0}}" Foreground="White" FontSize="14"/>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>