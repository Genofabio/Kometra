<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:converters="clr-namespace:Kometra.Converters"
        xmlns:vm="clr-namespace:Kometra.ViewModels.ImageProcessing"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="Kometra.Views.ImageEnhancementToolView"
        x:DataType="vm:ImageEnhancementToolViewModel"
        
        Width="900" Height="650" MinHeight="600" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ToolWindowBackgroundBrush}"
        Focusable="True">

    <Window.Title>
        <Binding Path="CurrentCategory">
            <Binding.Converter>
                <converters:EnhancementCategoryTitleConverter/>
            </Binding.Converter>
        </Binding>
    </Window.Title>

    <Window.Resources>
        <converters:EnhancementCategoryTitleConverter x:Key="TitleConverter" />
        <converters:ImageEnhancementModeConverter x:Key="ModeConverter" />
        <converters:ImageEnhancementDescriptionConverter x:Key="DescConverter" />
        <converters:EnumToBoolConverter x:Key="EnumToBool" />
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="/Styles/AlignmentToolStyles.axaml" />
        <Style Selector="TextBox.compact">
            <Setter Property="MinWidth" Value="65"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="12,0,0,0"/> 
        </Style>
        <Style Selector="TextBlock.labelInfo">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Help"/>
        </Style>
        <Style Selector="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,-4"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="380, *">
        
        <Border Grid.Column="0" Background="{DynamicResource ToolPanelBackgroundBrush}" Padding="15" IsEnabled="{Binding IsInteractionEnabled}">
            <Grid RowDefinitions="Auto, Auto, Auto, *, Auto, Auto">
                
                <TextBlock Grid.Row="0" Text="{Binding CurrentCategory, Converter={StaticResource TitleConverter}}" 
                           FontSize="20" FontWeight="Bold" Foreground="White" 
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" Spacing="8" IsEnabled="{Binding IsSetupControlsEnabled}">
                    <TextBlock Text="Algoritmo Selezionato" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding AvailableModes}" 
                              SelectedItem="{Binding SelectedMode}" 
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ., Converter={StaticResource ModeConverter}}"/> 
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Border Grid.Row="2" Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,15"/>

                <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" IsEnabled="{Binding IsSetupControlsEnabled}">
                    <StackPanel Spacing="25">
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="Descrizione" FontSize="11" Opacity="0.5" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedMode, Converter={StaticResource DescConverter}}" 
                                       FontStyle="Italic" Opacity="0.8" TextWrapping="Wrap" FontSize="12"/>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsLarsonSekaninaVisible}">
                            <TextBlock Text="Parametri Rotazione" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Angolo (gradi):" Classes="labelInfo" ToolTip.Tip="Angolo di rotazione per la sottrazione."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="-45" Maximum="45" Value="{Binding RotationAngle}"/>
                                        <TextBox x:Name="RotationBox" Text="{Binding RotationAngle, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Spostamento X (px):" Classes="labelInfo" ToolTip.Tip="Sposta il centro di rotazione orizzontalmente (sub-pixel)."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="-50" Maximum="50" Value="{Binding ShiftX}"/>
                                        <TextBox x:Name="ShiftXBox" Text="{Binding ShiftX, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Spostamento Y (px):" Classes="labelInfo" ToolTip.Tip="Sposta il centro di rotazione verticalmente (sub-pixel)."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="-50" Maximum="50" Value="{Binding ShiftY}"/>
                                        <TextBox x:Name="ShiftYBox" Text="{Binding ShiftY, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsAzimuthalContainerVisible}">
                            <TextBlock Text="Geometria Polare &amp; Modelli" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                
                                <StackPanel Spacing="2" IsVisible="{Binding IsAngularQualityVisible}">
                                    <TextBlock Text="Qualità Angolare:" Classes="labelInfo" ToolTip.Tip="Numero di settori angolari usati per calcolare la mediana."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="1" Maximum="20" Value="{Binding RadialSubsampling}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        <TextBox x:Name="SubsamplingBox" Text="{Binding RadialSubsampling, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="2" IsVisible="{Binding IsMaskRadiusVisible}">
                                    <TextBlock Text="Raggio Maschera (px):" Classes="labelInfo" ToolTip.Tip="Raggio massimo di applicazione del filtro. 0 = Tutta l'immagine."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0" Maximum="2500" Value="{Binding RadialMaxRadius}"/>
                                        <TextBox x:Name="McmRadiusBox" Text="{Binding RadialMaxRadius, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="2" IsVisible="{Binding IsAzimuthalRejectionVisible}">
                                    <TextBlock Text="Sigma Reiezione:" Classes="labelInfo" ToolTip.Tip="Soglia statistica per escludere le stelle durante il calcolo."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.5" Maximum="10" Value="{Binding AzimuthalRejSigma}"/>
                                        <TextBox x:Name="AzimuthalRejBox" Text="{Binding AzimuthalRejSigma, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                
                                <StackPanel Spacing="2" IsVisible="{Binding IsAzimuthalNormVisible}">
                                    <TextBlock Text="Scala Normalizzazione:" Classes="labelInfo" ToolTip.Tip="Fattore moltiplicativo per il contrasto dopo la rinormalizzazione."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="20" Value="{Binding AzimuthalNormSigma}"/>
                                        <TextBox x:Name="AzimuthalNormBox" Text="{Binding AzimuthalNormSigma, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsRvsfSingleVisible}">
                            <TextBlock Text="Parametri RVSF (Singolo)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Parametro A (Offset):" Classes="labelInfo" ToolTip.Tip="Offset radiale. Sposta l'inizio dell'effetto lontano dal nucleo."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0" Maximum="1000" Value="{Binding RvsfA_1}"/>
                                        <TextBox x:Name="RvsfA1Box" Text="{Binding RvsfA_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Parametro B (Scala):" Classes="labelInfo" ToolTip.Tip="Fattore di scala per la pendenza radiale."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0" Maximum="10" Value="{Binding RvsfB_1}"/>
                                        <TextBox x:Name="RvsfB1Box" Text="{Binding RvsfB_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Parametro N (Potenza):" Classes="labelInfo" ToolTip.Tip="Esponente della funzione. Valori &gt; 1 concentrano l'effetto all'esterno, &lt; 1 all'interno."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="5" Value="{Binding RvsfN_1}"/>
                                        <TextBox x:Name="RvsfN1Box" Text="{Binding RvsfN_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <CheckBox Content="Scala Logaritmica" IsChecked="{Binding UseLogScale}" Margin="0,0,0,0"
                                          ToolTip.Tip="Applica il filtro nello spazio logaritmico. Consigliato per immagini con alta dinamica."/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsRvsfMosaicVisible}">
                             <TextBlock Text="RVSF Mosaico (Range Parametri)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                             <StackPanel Spacing="8">
                                 <Grid ColumnDefinitions="*, 65, 30, 65">
                                    <TextBlock Text="Intervallo A:" Classes="labelInfo" VerticalAlignment="Center" ToolTip.Tip="Valore Minimo e Massimo per il Parametro A"/>
                                    <TextBox x:Name="RvsfAMinBox" Grid.Column="1" Text="{Binding RvsfA_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    <TextBlock Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox x:Name="RvsfAMaxBox" Grid.Column="3" Text="{Binding RvsfA_2, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, 65, 30, 65">
                                    <TextBlock Text="Intervallo B:" Classes="labelInfo" VerticalAlignment="Center" ToolTip.Tip="Valore Minimo e Massimo per il Parametro B"/>
                                    <TextBox x:Name="RvsfBMinBox" Grid.Column="1" Text="{Binding RvsfB_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    <TextBlock Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox x:Name="RvsfBMaxBox" Grid.Column="3" Text="{Binding RvsfB_2, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, 65, 30, 65">
                                    <TextBlock Text="Intervallo N:" Classes="labelInfo" VerticalAlignment="Center" ToolTip.Tip="Valore Minimo e Massimo per il Parametro N"/>
                                    <TextBox x:Name="RvsfNMinBox" Grid.Column="1" Text="{Binding RvsfN_1, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    <TextBlock Grid.Column="2" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox x:Name="RvsfNMaxBox" Grid.Column="3" Text="{Binding RvsfN_2, Mode=OneWay, StringFormat={}{0:F2}}"
                                             Classes="compact" HorizontalContentAlignment="Center" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                </Grid>

                                <CheckBox Content="Scala Logaritmica" IsChecked="{Binding UseLogScale}" Margin="0,0,0,0"
                                          ToolTip.Tip="Applica il filtro nello spazio logaritmico."/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsFrangiVisible}">
                            <TextBlock Text="Filtro Hessiana (Vesselness)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Sigma (Scala):" Classes="labelInfo" ToolTip.Tip="Scala delle strutture da rilevare. Aumenta per rilevare getti più spessi."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.5" Maximum="20" Value="{Binding FrangiSigma}"/>
                                        <TextBox x:Name="FrangiSigmaBox" Text="{Binding FrangiSigma, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Beta (Forma):" Classes="labelInfo" ToolTip.Tip="Sensibilità alla forma. Valori bassi selezionano solo linee molto sottili, valori alti includono blob."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="2.0" Value="{Binding FrangiBeta}"/>
                                        <TextBox x:Name="FrangiBetaBox" Text="{Binding FrangiBeta, Mode=OneWay, StringFormat={}{0:F2}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Costante C (Rumore):" Classes="labelInfo" ToolTip.Tip="Costante di soppressione del rumore di fondo."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.0001" Maximum="1.0" Value="{Binding FrangiC}"/>
                                        <TextBox x:Name="FrangiCBox" Text="{Binding FrangiC, Mode=OneWay, StringFormat={}{0:F4}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsTensorVisible}">
                            <TextBlock Text="Coerenza Tensore" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Sigma (Gradiente):" Classes="labelInfo" ToolTip.Tip="Smoothing gaussiano applicato prima del calcolo dei gradienti."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="1" Maximum="15" Value="{Binding TensorSigma}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        <TextBox x:Name="TensorSigmaBox" Text="{Binding TensorSigma, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Rho (Integrazione):" Classes="labelInfo" ToolTip.Tip="Finestra di integrazione per calcolare la coerenza direzionale locale."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="1" Maximum="30" Value="{Binding TensorRho}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        <TextBox x:Name="TensorRhoBox" Text="{Binding TensorRho, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsTopHatVisible}">
                            <TextBlock Text="Morfologia (Top-Hat)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Dimensione Kernel:" Classes="labelInfo" ToolTip.Tip="Dimensione dell'elemento strutturante. Strutture più grandi di questo valore verranno rimosse."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="3" Maximum="101" Value="{Binding TopHatKernelSize}" IsSnapToTickEnabled="True" TickFrequency="2"/>
                                        <TextBox x:Name="TopHatBox" Text="{Binding TopHatKernelSize, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsClaheVisible}">
                            <TextBlock Text="CLAHE (16-bit)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Limite Clipping:" Classes="labelInfo" ToolTip.Tip="Soglia massima di amplificazione del contrasto. Valori alti aumentano dettagli ma anche il rumore."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="40" Value="{Binding ClaheClipLimit}"/>
                                        <TextBox x:Name="ClaheClipBox" Text="{Binding ClaheClipLimit, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Dimensione Griglia:" Classes="labelInfo" ToolTip.Tip="Dimensione della griglia locale per il calcolo dell'istogramma."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="2" Maximum="64" Value="{Binding ClaheTileSize}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                        <TextBox x:Name="ClaheTileBox" Text="{Binding ClaheTileSize, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsLocalNormVisible}">
                            <TextBlock Text="Statistica Locale" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Dimensione Finestra:" Classes="labelInfo" ToolTip.Tip="Dimensione dell'area locale per il calcolo di media e deviazione standard."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="3" Maximum="201" Value="{Binding LocalNormWindowSize}" IsSnapToTickEnabled="True" TickFrequency="2"/>
                                        <TextBox x:Name="LocalNormWindowBox" Text="{Binding LocalNormWindowSize, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Intensità:" Classes="labelInfo" ToolTip.Tip="Forza del blending dell'effetto."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="0.1" Maximum="10" Value="{Binding LocalNormIntensity}"/>
                                        <TextBox x:Name="LocalNormIntensityBox" Text="{Binding LocalNormIntensity, Mode=OneWay, StringFormat={}{0:F1}}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsKernelVisible}">
                            <TextBlock Text="Unsharp Masking" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Dimensione Kernel:" Classes="labelInfo" ToolTip.Tip="Dimensione del filtro (es. mediana per Unsharp Masking)."/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Minimum="3" Maximum="101" Value="{Binding KernelSize}" IsSnapToTickEnabled="True" TickFrequency="2"/>
                                        <TextBox x:Name="KernelSizeBox" Text="{Binding KernelSize, Mode=OneWay}"
                                                 Grid.Column="1" Classes="compact" LostFocus="OnManualInputCommit" KeyDown="OnInputKeyDown"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="4" Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,15"/>

                <Panel Grid.Row="5">
                    <StackPanel Spacing="10" IsVisible="{Binding IsBusy}">
                        <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" FontSize="12" FontStyle="Italic"/>
                        <ProgressBar Value="{Binding ProgressValue}" 
                                     IsIndeterminate="{Binding ProgressValue, Converter={x:Static converters:ObjectConverters.IsZero}}" 
                                     Height="4" HorizontalAlignment="Stretch" 
                                     Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/>
                    </StackPanel>

                    <Button Content="Calcola Anteprima" Command="{Binding CalculatePreviewCommand}" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Classes="actionBtn calculate" IsVisible="{Binding IsCalculateButtonVisible}"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" IsVisible="{Binding IsApplyCancelButtonsVisible}">
                        <Button Grid.Column="0" Content="Indietro" Command="{Binding CancelCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Classes="actionBtn cancel"/>
                        <Button Grid.Column="1" Content="Applica Batch" Command="{Binding ApplyBatchCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Classes="actionBtn apply"/>
                    </Grid>
                </Panel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ToolWindowBackgroundBrush}" Padding="10">
            <Border Name="PreviewBorder" Background="{DynamicResource ToolPreviewBackgroundBrush}" ClipToBounds="True"
                    PointerPressed="OnPreviewPointerPressed" PointerReleased="OnPreviewPointerReleased" 
                    PointerMoved="OnPreviewPointerMoved" PointerWheelChanged="OnPreviewPointerWheelChanged">
                <Grid>
                    <Canvas Name="ViewportCanvas" RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Viewport.Scale}" ScaleY="{Binding Viewport.Scale}"/>
                                <TranslateTransform X="{Binding Viewport.OffsetX}" Y="{Binding Viewport.OffsetY}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                        <Image Source="{Binding ActiveRenderer.Image}" Stretch="None" RenderOptions.BitmapInterpolationMode="None"/>
                    </Canvas>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" 
                                HorizontalAlignment="Left" VerticalAlignment="Bottom" ZIndex="1" 
                                PointerPressed="OnControlsPointerPressed" IsEnabled="{Binding !IsBusy}">
                        <Button Command="{Binding Navigator.MoveToFirstCommand}" ToolTip.Tip="Prima Immagine"><avalonia:MaterialIcon Kind="ChevronDoubleLeft" Width="16" Height="16"/></Button>
                        <Button Command="{Binding Navigator.PreviousCommand}" ToolTip.Tip="Precedente"><avalonia:MaterialIcon Kind="ChevronLeft" Width="16" Height="16"/></Button>
                        <TextBlock Text="{Binding CurrentImageText}" VerticalAlignment="Center" Margin="10,0" Foreground="White" FontWeight="Bold"/>
                        <Button Command="{Binding Navigator.NextCommand}" ToolTip.Tip="Successiva"><avalonia:MaterialIcon Kind="ChevronRight" Width="16" Height="16"/></Button>
                        <Button Command="{Binding Navigator.MoveToLastCommand}" ToolTip.Tip="Ultima Immagine"><avalonia:MaterialIcon Kind="ChevronDoubleRight" Width="16" Height="16"/></Button>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" ZIndex="1" PointerPressed="OnControlsPointerPressed">
                        <Button Click="OnZoomOutClicked" ToolTip.Tip="Zoom Out"><avalonia:MaterialIcon Kind="Minus" Width="16" Height="16"/></Button>
                        <Button Click="OnZoomInClicked" ToolTip.Tip="Zoom In"><avalonia:MaterialIcon Kind="Plus" Width="16" Height="16"/></Button>
                        <Button Click="OnResetViewClicked" ToolTip.Tip="Adatta allo Schermo"><avalonia:MaterialIcon Kind="FitToScreen" Width="16" Height="16"/></Button>
                        <Path Data="M0,0 V18" Stroke="#666666" StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
                        <Button Command="{Binding ResetThresholdsCommand}" ToolTip.Tip="Resetta Visualizzazione"><avalonia:MaterialIcon Kind="Contrast" Width="16" Height="16"/></Button>
                    </StackPanel>
                    
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="8,4" 
                            Background="{DynamicResource OverlayTextBackgroundBrush}" CornerRadius="4">
                        <TextBlock Text="{Binding Viewport.Scale, StringFormat={}{0:P0}}" Foreground="White" FontSize="14"/>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>