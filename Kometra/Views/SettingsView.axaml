<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:vm="clr-namespace:Kometra.ViewModels.Settings"
        xmlns:infrastructure="clr-namespace:Kometra.Infrastructure"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="Kometra.Views.SettingsView"
        x:DataType="vm:SettingsViewModel"
        Icon="/Assets/Icon/icon32.ico"
        Title="{Binding [SettingsTitle], Source={x:Static infrastructure:LocalizationManager.Instance}}"
        Width="600" Height="500"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ToolWindowBackgroundBrush}"
        Focusable="True">

    <Window.Styles>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,15,0,5"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource Text.MediumGreyBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, Auto">
        
        <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,15">
            <TextBlock Text="{Binding [SettingsTitle], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                       FontSize="22" FontWeight="Bold" Foreground="White"/>
            <Separator Background="{DynamicResource Border.WhiteDimBrush}" Opacity="0.3" Margin="0,5"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">

                <TextBlock Classes="sectionTitle" Text="{Binding [GeneralSettings], Source={x:Static infrastructure:LocalizationManager.Instance}}" Margin="0,0,0,5"/>
                
                <Grid ColumnDefinitions="200, *" Margin="10,0,0,0">
                    <TextBlock Grid.Column="0" Classes="label" Text="{Binding [Language], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Separator Background="{DynamicResource Border.WhiteDimBrush}" Opacity="0.1" Margin="0,10"/>

                <TextBlock Classes="sectionTitle" Text="{Binding [InterfaceSettings], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                
                <Grid ColumnDefinitions="200, *" RowDefinitions="Auto, 10, Auto" Margin="10,0,0,0">
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Board Background Color (Hex)"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BoardBackgroundColor}" Height="30"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Primary Selection Color (Hex)"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PrimarySelectionColor}" Height="30"/>
                </Grid>

                <Separator Background="{DynamicResource Border.WhiteDimBrush}" Opacity="0.1" Margin="0,10"/>

                <TextBlock Classes="sectionTitle" Text="External Engines"/>
                
                <Grid ColumnDefinitions="200, *" Margin="10,0,0,0">
                    <TextBlock Grid.Column="0" Classes="label" Text="ASTAP Executable Path"/>
                    <Grid Grid.Column="1" ColumnDefinitions="*, Auto">
                        <TextBox Grid.Column="0" Text="{Binding AstapPath}" Height="30" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" ToolTip.Tip="Browse...">
                            <avalonia:MaterialIcon Kind="FolderOpen" Width="18" Height="18"/>
                        </Button>
                    </Grid>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <Separator Background="{DynamicResource Border.WhiteDimBrush}" Opacity="0.3" Margin="0,0,0,15"/>
            <Grid ColumnDefinitions="*, 10, *">
                <Button Grid.Column="0" Content="{Binding [Cancel], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                        Command="{Binding CancelCommand}" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                
                <Button Grid.Column="2" Content="{Binding [Save], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                        Command="{Binding SaveCommand}" 
                        Background="{DynamicResource ActionPrimaryBackgroundBrush}" Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>