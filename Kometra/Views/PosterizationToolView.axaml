<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:conv="clr-namespace:Kometra.Converters"
        xmlns:imageProcessing="clr-namespace:Kometra.ViewModels.ImageProcessing"
        mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="650"
        x:Class="Kometra.Views.PosterizationToolView"
        x:DataType="imageProcessing:PosterizationToolViewModel"
        
        Title="Analisi Morfologica / Posterizzazione"
        Width="1000" Height="600"
        MinHeight="500" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ToolWindowBackgroundBrush}"
        Focusable="True">

    <Window.Resources>
        <conv:PosterizationModeConverter x:Key="ModeConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.description">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style Selector="TextBox.valueInput">
            <Setter Property="MinWidth" Value="60"/>       <Setter Property="Height" Value="28"/>         <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Margin" Value="10,0,0,0"/>   <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>       <Setter Property="FontSize" Value="12"/>       </Style>
    </Window.Styles>
    
    <Grid ColumnDefinitions="320, *">
        
        <Border Grid.Column="0" Background="{DynamicResource ToolPanelBackgroundBrush}" Padding="10,14,10,6">
            <Grid RowDefinitions="Auto, *, Auto">
                
                <TextBlock Grid.Row="0" Text="Parametri Quantizzazione" FontSize="22" FontWeight="Bold" 
                           Foreground="{DynamicResource Text.StaticWhiteBrush}" Margin="5,0,0,15"/>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="15" Margin="5,0,14,0">
                        
                        <StackPanel Spacing="2">
                            <TextBlock Classes="sectionTitle" Text="Numero Livelli"/>
                            <TextBlock Classes="description" Text="Divide l'immagine in toni discreti per isolare le isofote."/>
                            
                            <Grid ColumnDefinitions="*, Auto">
                                <Slider Grid.Column="0" Minimum="2" Maximum="{Binding MaxLevels}" Value="{Binding Levels}" 
                                        IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
                                <TextBox Name="LevelsInput" Grid.Column="1" Classes="valueInput"
                                         Text="{Binding Levels, Mode=OneWay}" 
                                         LostFocus="OnValueInputLostFocus" KeyDown="OnInputKeyDown"/>
                            </Grid>
                        </StackPanel>
                        
                        <Border Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,4"/>
                        
                        <StackPanel Spacing="2">
                            <TextBlock Classes="sectionTitle" Text="Metodo Distribuzione"/>
                            <TextBlock Classes="description" Text="Scegli come ripartire i toni per enfatizzare dettagli deboli."/>
                            <ComboBox ItemsSource="{Binding AvailableModes}" 
                                      SelectedItem="{Binding SelectedMode}" 
                                      HorizontalAlignment="Stretch" Margin="0,6,0,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Converter={StaticResource ModeConverter}}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        
                        <Border Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,4"/>
                        
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="0">
                                <TextBlock Classes="sectionTitle" Text="Range Dinamico (Clip)"/>
                                <TextBlock Classes="description" Text="Definisce l'intervallo di segnale ADU (0-65535)."/>
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Soglia Nero" FontSize="11" Foreground="{DynamicResource Text.MediumGreyBrush}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <Slider Grid.Column="0" Minimum="0" Maximum="65535" Value="{Binding BlackPoint}" VerticalAlignment="Center"/>
                                    <TextBox Name="BlackInput" Grid.Column="1" Classes="valueInput"
                                             Text="{Binding BlackPoint, Mode=OneWay, StringFormat={}{0:0.0}}" 
                                             LostFocus="OnValueInputLostFocus" KeyDown="OnInputKeyDown"/>
                                </Grid>
                            </StackPanel>
                            
                            <StackPanel Spacing="2">
                                <TextBlock Text="Soglia Bianco" FontSize="11" Foreground="{DynamicResource Text.MediumGreyBrush}" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <Slider Grid.Column="0" Minimum="0" Maximum="65535" Value="{Binding WhitePoint}" VerticalAlignment="Center"/>
                                    <TextBox Name="WhiteInput" Grid.Column="1" Classes="valueInput"
                                             Text="{Binding WhitePoint, Mode=OneWay, StringFormat={}{0:0.0}}" 
                                             LostFocus="OnValueInputLostFocus" KeyDown="OnInputKeyDown"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,4"/>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Classes="sectionTitle" Text="Opzioni aggiuntive"/>
                            <CheckBox IsChecked="{Binding AutoAdaptThresholds}" Padding="8,0,0,0" FontSize="12" 
                                      Content="Adatta luminosità al cambio immagine" Margin="0,0,0,6"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="5,12,5,0">
                    <Border Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,0,0,10"/>
                    <StackPanel Spacing="10">
                        <StackPanel Spacing="5" IsVisible="{Binding IsProcessing}">
                            <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" FontSize="12" FontStyle="Italic" Foreground="{DynamicResource Text.MediumGreyBrush}"/>
                            <ProgressBar IsIndeterminate="True" Height="4" Foreground="{DynamicResource ActionPrimaryBackgroundBrush}"/>
                        </StackPanel>
                        
                        <Button Content="Applica" Command="{Binding ApplyCommand}" Classes="actionBtn apply" IsEnabled="{Binding !IsProcessing}" Margin="0,8,0,10"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ToolWindowBackgroundBrush}" Padding="10">
            <Border Name="PreviewBorder" Background="{DynamicResource ToolPreviewBackgroundBrush}" ClipToBounds="True"
                    PointerPressed="OnPreviewPointerPressed"
                    PointerReleased="OnPreviewPointerReleased"
                    PointerMoved="OnPreviewPointerMoved"
                    PointerWheelChanged="OnPreviewPointerWheelChanged"
                    SizeChanged="OnPreviewSizeChanged">
                <Grid>
                    <Canvas Name="Viewport" RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Viewport.Scale}" ScaleY="{Binding Viewport.Scale}"/>
                                <TranslateTransform X="{Binding Viewport.OffsetX}" Y="{Binding Viewport.OffsetY}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                        <Image Name="PreviewImage" Source="{Binding ActiveRenderer.Image}" Stretch="None" RenderOptions.BitmapInterpolationMode="None"/>
                        <Canvas Name="InteractionCanvas" Background="Transparent" 
                                Width="{Binding Viewport.ImageSize.Width}" 
                                Height="{Binding Viewport.ImageSize.Height}" />
                    </Canvas>

                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="8,4" 
                            Background="{DynamicResource OverlayTextBackgroundBrush}" CornerRadius="4" IsHitTestVisible="False">
                        <TextBlock Text="{Binding Viewport.Scale, StringFormat={}{0:P0}}" 
                                   Foreground="{DynamicResource OverlayTextForegroundBrush}" FontSize="14"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" ZIndex="1" IsVisible="{Binding IsNavigationVisible}">
                        <Button Command="{Binding Navigator.PreviousCommand}" ToolTip.Tip="Immagine Precedente">
                            <avalonia:MaterialIcon Kind="ChevronLeft" Width="16" Height="16"/>
                        </Button>
                        <TextBlock Text="{Binding CurrentImageText}" VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource Text.StaticWhiteBrush}" FontWeight="SemiBold" FontSize="13"/>
                        <Button Command="{Binding Navigator.NextCommand}" ToolTip.Tip="Immagine Successiva">
                            <avalonia:MaterialIcon Kind="ChevronRight" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" ZIndex="1">
                        <Button Click="OnZoomOutClicked" ToolTip.Tip="Zoom Out">
                            <avalonia:MaterialIcon Kind="Minus" Width="16" Height="16"/>
                        </Button>
                        <Button Click="OnZoomInClicked" ToolTip.Tip="Zoom In">
                            <avalonia:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                        </Button>
                        <Button Click="OnResetViewClicked" Margin="8,0,0,0" ToolTip.Tip="Adatta allo schermo">
                            <avalonia:MaterialIcon Kind="FitToScreen" Width="16" Height="16"/>
                        </Button>
                        
                        <Path Data="M0,0 V18" Stroke="{DynamicResource ActionDisabledBackgroundBrush}" StrokeThickness="1" Margin="8,4,8,4" VerticalAlignment="Center" />
                        
                        <Button Command="{Binding ResetThresholdsCommand}" ToolTip.Tip="Reset Stretch (Livelli)">
                            <avalonia:MaterialIcon Kind="Contrast" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>