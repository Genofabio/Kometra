<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:astrometry="clr-namespace:Kometra.ViewModels.Astrometry"
        xmlns:infrastructure="clr-namespace:Kometra.Infrastructure"
        mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="550"
        x:Class="Kometra.Views.PlateSolvingToolView"
        x:DataType="astrometry:PlateSolvingToolViewModel"
        x:Name="RootWindow"
        Icon="/Assets/Icon/icon.ico"
        Title="{Binding [PlateTitle], Source={x:Static infrastructure:LocalizationManager.Instance}}"
        Width="650" Height="550"
        MinWidth="650" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource ToolWindowBackgroundBrush}">

    <Border Padding="20" Background="Transparent">
        <Grid RowDefinitions="Auto, Auto, *, Auto" RowSpacing="15">

            <StackPanel Grid.Row="0" Spacing="10">
                <TextBlock Classes="TitleText" Text="{Binding Title}"/>
                <TextBlock Classes="DescriptionText" 
                           Text="{Binding [PlateDesc], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                <Border Height="1" Background="{DynamicResource ActionDisabledBackgroundBrush}" Margin="0,5"/>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Classes="TargetLabel" Text="{Binding [PlateTargetLabel], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                    <TextBlock Classes="TargetValue" Text="{Binding TargetName}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="8">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="14"/>
                    
                    <StackPanel Orientation="Horizontal" Grid.Column="1" IsVisible="{Binding IsBusyState}">
                        <TextBlock Text="{Binding [PlateProcessedLabel], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                                   Foreground="{DynamicResource Text.MediumGreyBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding ProgressValue}" Margin="4,0,0,0"
                                   Foreground="{DynamicResource Text.MediumGreyBrush}" FontSize="12"/>
                    </StackPanel>
                </Grid>
                <ProgressBar Height="6" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                             IsVisible="{Binding IsBusyState}" 
                             Foreground="{DynamicResource ActionPrimaryBackgroundBrush}" 
                             Background="{DynamicResource MenuBackgroundBrush}"/>
            </StackPanel>

            <Border Grid.Row="2" Classes="LogContainer">
                <TextBox Classes="LogContent"
                         Text="{Binding FullLog}" 
                         IsReadOnly="True" 
                         CaretIndex="{Binding FullLog.Length}"/>
            </Border>

            <StackPanel Grid.Row="3" Spacing="15">
                
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <avalonia:MaterialIcon Kind="AlertCircleOutline" Width="16" Height="16" 
                                           Foreground="{DynamicResource OverlaySearchBoxBrush}"/>
                    <TextBlock Classes="WarningLabel" Text="{Binding [PlateWarningLabel], Source={x:Static infrastructure:LocalizationManager.Instance}}" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Classes="WarningBody" Margin="0"
                               Text="{Binding [PlateWarningBody], Source={x:Static infrastructure:LocalizationManager.Instance}}" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                                IsVisible="{Binding IsInitialState}">
                        <Button Classes="baseBtn calculate" 
                                Command="{Binding StartSolvingCommand}"
                                Content="{Binding [PlateStart], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                                IsVisible="{Binding IsBusyState}">
                        <Button Classes="baseBtn cancel" 
                                Command="{Binding CancelCommand}"
                                Content="{Binding [PlateStop], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" 
                                IsVisible="{Binding IsFinishedState}">
        
                        <Button Classes="baseBtn calculate" 
                                Command="{Binding StartSolvingCommand}"
                                Content="{Binding [PlateRestart], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>

                        <Button Classes="baseBtn cancel" 
                                Command="{Binding CloseCommand}"
                                Content="{Binding [Cancel], Source={x:Static infrastructure:LocalizationManager.Instance}}"/>

                        <Button Classes="baseBtn apply" 
                                Command="{Binding ApplyResultsCommand}"
                                Content="{Binding [Save], Source={x:Static infrastructure:LocalizationManager.Instance}}"
                                IsEnabled="{Binding CanApply}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
            
        </Grid>
    </Border>
</Window>