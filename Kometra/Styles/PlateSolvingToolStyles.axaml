<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Button.baseBtn">
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="25,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Button.calculate">
        <Setter Property="Background" Value="{DynamicResource ActionPrimaryBackgroundBrush}"/> 
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.calculate:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionPrimaryHoverBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.calculate:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionPrimaryPressedBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.calculate:disabled">
        <Setter Property="Background" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <Style Selector="Button.apply">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessBackgroundBrush}"/> 
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.apply:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessHoverBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.apply:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionSuccessPressedBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.apply:disabled">
        <Setter Property="Background" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <Style Selector="Button.cancel">
        <Setter Property="Background" Value="{DynamicResource ActionDestructiveBackgroundBrush}"/> 
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.cancel:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionDestructiveHoverBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>
    <Style Selector="Button.cancel:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActionDestructivePressedBrush}"/> 
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>

    <Style Selector="TextBlock.TitleText">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.StaticWhiteBrush}"/>
    </Style>

    <Style Selector="TextBlock.DescriptionText">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.MediumGreyBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.LogContainer">
        <Setter Property="Background" Value="{DynamicResource ToolPreviewBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="TextBox.LogContent">
        <Setter Property="FontFamily" Value="Consolas, Monospace"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource NavButtonForegroundBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="TextBlock.WarningLabel">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Text.MediumGreyBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="TextBlock.WarningBody">
        <Setter Property="Foreground" Value="{DynamicResource ActionDisabledBackgroundBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="Margin" Value="0"/> 
    </Style>
</Styles>