<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Kometra.Controls">

    <Style Selector="controls|ConnectionControl">
        <Setter Property="InactiveBrush" Value="{DynamicResource ActionDisabledBackgroundBrush}" />
        <Setter Property="DefaultBrush" Value="{DynamicResource ImageBorderBrush}" />
        <Setter Property="SelectedBrush" Value="{DynamicResource ImageSelectionBrush}" />
        
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>

</Styles>